{
  "$ref": "#/definitions/blog",
  "definitions": {
    "blog": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 70
        },
        "description": {
          "type": "string",
          "minLength": 120,
          "maxLength": 160
        },
        "publishedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "author": {
          "type": "string",
          "default": "Equipo AgentesVA"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pillar": {
          "type": "string",
          "enum": [
            "kit-digital",
            "whatsapp-api",
            "automatizacion-ia-pymes",
            "comparativas",
            "agentes-ia-concepto",
            "caso-estudio"
          ]
        },
        "industria": {
          "type": "string",
          "enum": [
            "restaurante",
            "escuela-idiomas",
            "renting",
            "consultorio",
            "inmobiliaria",
            "ecommerce",
            "agencia",
            "farmacia",
            "salon",
            "gimnasio",
            "consultoria",
            "academia",
            "general"
          ],
          "default": "general"
        },
        "youtubeId": {
          "type": "string"
        },
        "casoRelacionado": {
          "type": "string"
        },
        "ogImage": {
          "type": "string"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "readingTimeMin": {
          "type": "integer",
          "minimum": 2,
          "maximum": 45
        },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            },
            "required": [
              "q",
              "a"
            ],
            "additionalProperties": false
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "publishedAt",
        "tags",
        "pillar"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}