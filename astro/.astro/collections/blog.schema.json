{
  "$ref": "#/definitions/blog",
  "definitions": {
    "blog": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "publishedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "author": {
          "type": "string",
          "default": "Equipo AgentesVA"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pillar": {
          "type": "string",
          "enum": [
            "automatizacion-ia-pymes",
            "make-tutorial",
            "caso-estudio",
            "noticias"
          ]
        },
        "industria": {
          "type": "string"
        },
        "youtubeId": {
          "type": "string"
        },
        "ogImage": {
          "type": "string"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "publishedAt",
        "tags",
        "pillar"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}