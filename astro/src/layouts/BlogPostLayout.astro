---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import PillarPill from '../components/PillarPill.astro';
import PostMeta from '../components/PostMeta.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import JsonLd from '../components/JsonLd.astro';

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    publishedAt: Date;
    updatedAt?: Date;
    author: string;
    tags: string[];
    pillar:
      | 'kit-digital'
      | 'whatsapp-api'
      | 'automatizacion-ia-pymes'
      | 'comparativas'
      | 'agentes-ia-concepto'
      | 'caso-estudio';
    ogImage?: string;
    youtubeId?: string;
    readingTimeMin?: number;
  };
  slug: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { frontmatter, slug, headings = [] } = Astro.props;
const url = `https://agentesva.com/blog/${slug}/`;

// Reading time fallback (rough estimate: not used because we don't have raw content here;
// posts should set readingTimeMin in frontmatter — schema enforces 2-45 if provided).
const readingTimeMin = frontmatter.readingTimeMin;

// Filter TOC: only H2/H3
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: new Date(frontmatter.publishedAt).toISOString(),
  dateModified: new Date(frontmatter.updatedAt || frontmatter.publishedAt).toISOString(),
  author: { '@type': 'Organization', name: frontmatter.author || 'AgentesVA' },
  publisher: {
    '@type': 'Organization',
    name: 'AgentesVA',
    logo: {
      '@type': 'ImageObject',
      url: 'https://agentesva.com/assets/logo.png',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  image: frontmatter.ogImage || 'https://agentesva.com/assets/og-home.png',
  keywords: frontmatter.tags.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://agentesva.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://agentesva.com/blog/' },
    { '@type': 'ListItem', position: 3, name: frontmatter.title, item: url },
  ],
};

const schemas: Record<string, any>[] = [articleSchema, breadcrumbSchema];

if (frontmatter.youtubeId) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: frontmatter.title,
    description: frontmatter.description,
    thumbnailUrl: `https://i.ytimg.com/vi/${frontmatter.youtubeId}/maxresdefault.jpg`,
    uploadDate: new Date(frontmatter.publishedAt).toISOString(),
    contentUrl: `https://www.youtube.com/watch?v=${frontmatter.youtubeId}`,
    embedUrl: `https://www.youtube.com/embed/${frontmatter.youtubeId}`,
  });
}
---
<BaseLayout
  title={`${frontmatter.title} — AgentesVA`}
  description={frontmatter.description}
  canonical={url}
  ogImage={frontmatter.ogImage}
  ogType="article"
>
  <JsonLd slot="head" data={schemas} />
  <Header />

  <article class="bg-paper">
    <header class="container max-w-[760px] pt-16 md:pt-24 pb-8">
      <nav class="text-xs text-ink-3 mb-6" aria-label="Migas de pan">
        <a href="/" class="hover:text-clay transition">Inicio</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <a href="/blog/" class="hover:text-clay transition">Blog</a>
      </nav>
      <div class="mb-5">
        <PillarPill pillar={frontmatter.pillar} />
      </div>
      <h1 class="font-serif text-4xl md:text-6xl leading-tight tracking-tight text-ink mb-6">
        {frontmatter.title}
      </h1>
      <p class="text-lg md:text-xl text-ink-2 leading-relaxed mb-6">
        {frontmatter.description}
      </p>
      <PostMeta
        publishedAt={frontmatter.publishedAt}
        readingTimeMin={readingTimeMin}
        author={frontmatter.author}
      />
    </header>

    <!-- Hero image removed by design — small gradient thumbs in cards instead -->

    <div class="container max-w-[1100px] pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-12">
        <div class="prose prose-blog max-w-[760px] mx-auto lg:mx-0">
          <slot />

          <ShareButtons url={url} title={frontmatter.title} />

          <div class="mt-12 p-8 bg-card border border-line rounded-lg">
            <p class="text-xs uppercase tracking-wider text-ink-3 mb-3 font-mono">Sobre el autor</p>
            <p class="text-base text-ink-2 leading-relaxed mb-3">
              <strong class="text-ink">{frontmatter.author}</strong> · Consultoría de automatización con IA para PyMEs en España. Stack Make + Claude + HubSpot.
            </p>
            <a href="/sobre/" class="text-sm text-clay hover:text-clay-deep font-medium">Más sobre AgentesVA →</a>
          </div>

          <div class="mt-8 p-8 md:p-10 bg-ink text-paper rounded-lg">
            <p class="text-xs uppercase tracking-wider text-paper/60 mb-3 font-mono">Siguiente paso</p>
            <h3 class="font-serif text-2xl md:text-3xl mb-4 text-paper">¿Quieres aplicar esto a tu negocio?</h3>
            <p class="text-paper/80 mb-6 leading-relaxed">
              Reserva una auditoría gratuita de 30 minutos. Revisamos tus procesos y diseñamos un mapa concreto de automatización.
            </p>
            <a
              href="https://calendly.com/fangaiala/auditoria-gratis-agentesva-30-min"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-clay text-paper font-medium hover:bg-clay-deep transition"
            >
              Reservar auditoría gratis →
            </a>
          </div>
        </div>

        {toc.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <p class="text-xs uppercase tracking-wider text-ink-3 mb-4 font-mono">En esta página</p>
              <nav>
                <ul class="space-y-2 text-sm">
                  {toc.map((h) => (
                    <li class={h.depth === 3 ? 'pl-4' : ''}>
                      <a
                        href={`#${h.slug}`}
                        class="text-ink-2 hover:text-clay transition leading-snug block py-1"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )}
      </div>

      <RelatedPosts currentSlug={slug} tags={frontmatter.tags} pillar={frontmatter.pillar} />
    </div>
  </article>

  <Footer />
  <MobileNav />
</BaseLayout>

<style is:global>
  .prose.prose-blog {
    color: var(--ink-2);
    font-size: 18px;
    line-height: 1.75;
  }
  .prose.prose-blog > * + * { margin-top: 1.5em; }
  .prose.prose-blog h2 {
    font-family: var(--serif);
    font-size: clamp(28px, 3vw, 36px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-top: 2.4em;
    margin-bottom: 0.6em;
    font-weight: 400;
    scroll-margin-top: 100px;
  }
  .prose.prose-blog h3 {
    font-family: var(--serif);
    font-size: clamp(22px, 2.2vw, 26px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin-top: 2em;
    margin-bottom: 0.5em;
    font-weight: 500;
    scroll-margin-top: 100px;
  }
  .prose.prose-blog h4 {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    margin-top: 1.6em;
    margin-bottom: 0.4em;
  }
  .prose.prose-blog p { margin: 1.2em 0; }
  .prose.prose-blog a {
    color: var(--clay);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  .prose.prose-blog a:hover { color: var(--clay-deep); }
  .prose.prose-blog strong { color: var(--ink); font-weight: 600; }
  .prose.prose-blog em { font-style: italic; }
  .prose.prose-blog ul, .prose.prose-blog ol { margin: 1.2em 0; padding-left: 1.5em; }
  .prose.prose-blog ul { list-style: disc; }
  .prose.prose-blog ol { list-style: decimal; }
  .prose.prose-blog li { margin: 0.5em 0; }
  .prose.prose-blog li::marker { color: var(--clay); }
  .prose.prose-blog blockquote {
    border-left: 3px solid var(--clay);
    padding: 0.5em 1.5em;
    margin: 1.8em 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1em;
    color: var(--ink-2);
    background: var(--card);
    border-radius: 0 var(--r-md) var(--r-md) 0;
  }
  .prose.prose-blog code {
    font-family: var(--mono);
    font-size: 0.88em;
    background: var(--paper-2);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--clay-deep);
  }
  .prose.prose-blog pre {
    background: var(--ink);
    color: var(--paper);
    padding: 1.2em 1.4em;
    border-radius: var(--r-md);
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.6;
    margin: 1.5em 0;
  }
  .prose.prose-blog pre code {
    background: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
  }
  .prose.prose-blog img {
    width: 100%;
    border-radius: var(--r-md);
    margin: 1.8em 0;
  }
  .prose.prose-blog hr {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 2.5em 0;
  }
  .prose.prose-blog table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 0.95em;
  }
  .prose.prose-blog th, .prose.prose-blog td {
    padding: 0.7em 1em;
    border-bottom: 1px solid var(--line);
    text-align: left;
  }
  .prose.prose-blog th {
    font-family: var(--mono);
    font-size: 0.78em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    font-weight: 500;
  }
</style>
