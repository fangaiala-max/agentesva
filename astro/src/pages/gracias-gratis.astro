---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';

const bodyHtml = `<main class="max-w-2xl mx-auto px-6 py-12 pb-32 md:pb-16">

    <!-- ==================== CONFIRMATION ==================== -->
    <div class="flex flex-col items-center gap-4 mb-12 text-center">
        <div class="animate-pop-in w-[80px] h-[80px] bg-ink rounded-full flex items-center justify-center shadow-2xl">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none"
                 stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                 stroke-dasharray="36" stroke-dashoffset="36" class="animate-check">
                <polyline points="8,18 15,25 28,12"/>
            </svg>
        </div>
        <div>
            <p class="font-serif text-2xl md:text-3xl font-black text-ink">&iexcl;Tu agente est&aacute; en camino!</p>
            <p class="text-ink-3 mt-2 max-w-sm mx-auto text-sm leading-relaxed">Revisa tu email en los pr&oacute;ximos 5 minutos. Incluye el blueprint, la gu&iacute;a de activaci&oacute;n, y un video de 2 minutos para tenerlo funcionando hoy.</p>
        </div>
    </div>

    <!-- ==================== EMAIL BOX ==================== -->
    <div class="bg-ink/5 border-2 border-clay/10 rounded-2xl p-8 mb-10 text-center">
        <div class="text-4xl mb-4">&#x1F4EC;</div>
        <p class="font-bold text-ink text-base mb-2">Qu&eacute; llega en tu email</p>
        <p class="text-sm text-ink-3 mb-5">Revisa tambi&eacute;n en tu carpeta de spam si no lo ves en 5 minutos.</p>
        <div class="flex flex-col gap-2 text-left">
            <div class="flex items-center gap-3 bg-paper rounded-xl px-4 py-3">
                <span class="text-xl flex-shrink-0">&#x1F4C4;</span>
                <span class="text-sm text-ink">El blueprint (.json) listo para importar en Make.com</span>
            </div>
            <div class="flex items-center gap-3 bg-paper rounded-xl px-4 py-3">
                <span class="text-xl flex-shrink-0">&#x1F4D8;</span>
                <span class="text-sm text-ink">Gu&iacute;a de activaci&oacute;n paso a paso con capturas</span>
            </div>
            <div class="flex items-center gap-3 bg-paper rounded-xl px-4 py-3">
                <span class="text-xl flex-shrink-0">&#x25B6;&#xFE0F;</span>
                <span class="text-sm text-ink">Video de 2 minutos para tenerlo funcionando hoy</span>
            </div>
        </div>
    </div>

    <!-- ==================== UPSELL ==================== -->
    <div class="mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-clay mb-2">Mientras esperas</p>
        <h2 class="font-serif text-xl font-bold text-ink mb-2">Estos son los agentes que mejor complementan al que acabas de elegir</h2>
        <p class="text-sm text-ink-3 mb-5">Los m&aacute;s elegidos por due&ntilde;os de negocio que ya automatizaron su primer proceso.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a href="/catalogo/" class="block bg-ink/5 border border-clay/10 rounded-2xl p-6 hover:shadow-lg transition-all hover:-translate-y-1 no-underline">
                <div class="text-3xl mb-3">&#x23F0;</div>
                <p class="font-bold text-ink text-sm mb-1">Recordatorio de Citas</p>
                <p class="font-serif text-xl font-black text-clay mb-2">$29</p>
                <p class="text-xs text-ink-3 leading-relaxed">Recupera citas perdidas desde el d&iacute;a 1.</p>
            </a>
            <a href="/catalogo/" class="block bg-ink/5 border border-clay/10 rounded-2xl p-6 hover:shadow-lg transition-all hover:-translate-y-1 no-underline">
                <div class="text-3xl mb-3">&#x1F4AC;</div>
                <p class="font-bold text-ink text-sm mb-1">Automatizador de Follow-ups</p>
                <p class="font-serif text-xl font-black text-clay mb-2">$47</p>
                <p class="text-xs text-ink-3 leading-relaxed">El seguimiento que cierra ventas, sin esfuerzo.</p>
            </a>
            <a href="/catalogo/" class="block bg-ink/5 border border-clay/10 rounded-2xl p-6 hover:shadow-lg transition-all hover:-translate-y-1 no-underline">
                <div class="text-3xl mb-3">&#x1F4CA;</div>
                <p class="font-bold text-ink text-sm mb-1">Integrador CRM Universal</p>
                <p class="font-serif text-xl font-black text-clay mb-2">Avanzado</p>
                <p class="text-xs text-ink-3 leading-relaxed">Todos tus leads en un solo lugar.</p>
            </a>
        </div>
    </div>

    <!-- ==================== CTA ==================== -->
    <div class="flex items-center gap-4 flex-wrap">
        <a href="/catalogo/" class="px-8 py-4 bg-gradient-to-r from-ink to-clay-wash text-paper font-bold rounded-full shadow-lg hover:shadow-xl transition-all active:scale-95">Explorar todos los agentes &rarr;</a>
        <a href="/" class="text-sm text-ink-3 hover:text-ink transition-colors">Volver al inicio</a>
    </div>

</main>

<!-- ==================== FOOTER ==================== -->`;
---
<BaseLayout
  title={`¡Tu agente está en camino! | AgentesVA`}
  description={`Tu agente gratuito está en camino. Revisa tu email en 5 minutos.`}
  canonical="https://agentesva.com/gracias-gratis/"
  ogImage="https://agentesva.com/assets/og-home.png"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
    <link rel="alternate" hreflang="es" href="https://agentesva.com/gracias-gratis/" />
    <link rel="alternate" hreflang="es-MX" href="https://agentesva.com/gracias-gratis/" />
    <link rel="alternate" hreflang="es-CO" href="https://agentesva.com/gracias-gratis/" />
    <link rel="alternate" hreflang="es-AR" href="https://agentesva.com/gracias-gratis/" />
    <link rel="alternate" hreflang="es-CL" href="https://agentesva.com/gracias-gratis/" />
    <link rel="alternate" hreflang="es-PE" href="https://agentesva.com/gracias-gratis/" />
    <link rel="alternate" hreflang="x-default" href="https://agentesva.com/" />
    
  </Fragment>

  <Header />

  <Fragment set:html={bodyHtml} />

  <Footer />
  <MobileNav />
</BaseLayout>

<style is:global>
.material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        font-family: 'Material Symbols Outlined';
        font-style: normal;
        display: inline-block;
        line-height: 1;
        text-transform: none;
        letter-spacing: normal;
        word-wrap: normal;
        white-space: nowrap;
        direction: ltr;
      }
      @keyframes popIn {
        from { transform: scale(0); opacity: 0; }
        to   { transform: scale(1); opacity: 1; }
      }
      @keyframes checkDraw {
        from { stroke-dashoffset: 36; opacity: 0; }
        to   { stroke-dashoffset: 0;  opacity: 1; }
      }
      .animate-pop-in { animation: popIn 0.6s cubic-bezier(0.34,1.56,0.64,1) both; }
      .animate-check  { animation: checkDraw 0.4s ease 0.4s both; }
</style>
