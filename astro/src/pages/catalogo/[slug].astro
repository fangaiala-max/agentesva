---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MobileNav from '../../components/MobileNav.astro';
import JsonLd from '../../components/JsonLd.astro';
import { industriasCatalog } from '../../data/industrias-catalog';
import type { IndustriaCatalog } from '../../data/industrias-catalog';
import { agents, CALENDLY_URL } from '../../data/agents';

export async function getStaticPaths() {
  return industriasCatalog.map((ind) => ({
    params: { slug: ind.slug },
    props: { industria: ind },
  }));
}

interface Props { industria: IndustriaCatalog }
const { industria } = Astro.props;

const recommendedAgents = industria.agentesRecomendados
  .map((id) => agents.find((a) => a.id === id))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));

const filterParam = industria.industriaFilter
  ? `?filter=ind-${encodeURIComponent(industria.industriaFilter)}`
  : '';
const catalogLink = `/catalogo/${filterParam}`;

const canonical = `https://agentesva.com/catalogo/${industria.slug}/`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Automatización con IA para ${industria.nombre}`,
  description: industria.seoDescription,
  provider: {
    '@type': 'Organization',
    name: 'AgentesVA',
    url: 'https://agentesva.com',
  },
  areaServed: ['ES', 'MX', 'CO', 'AR', 'CL', 'PE'],
  availableLanguage: 'es',
  offers: {
    '@type': 'Offer',
    name: 'Auditoría gratis de automatización',
    price: '0',
    priceCurrency: 'EUR',
    url: CALENDLY_URL,
    availability: 'https://schema.org/InStock',
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `AgentesVA — IA para ${industria.nombre}`,
  description: industria.seoDescription,
  url: canonical,
  image: 'https://agentesva.com/logo.svg',
  areaServed: ['ES', 'MX', 'CO', 'AR', 'CL', 'PE'],
  serviceType: 'IA Automation Service',
  priceRange: '$',
};

const hreflangs = ['es', 'es-ES', 'es-MX', 'es-CO', 'es-AR', 'es-CL', 'es-PE'];
---
<BaseLayout
  title={industria.seoTitle}
  description={industria.seoDescription}
  canonical={canonical}
>
  <Fragment slot="head">
    {hreflangs.map((lang) => (
      <link rel="alternate" hreflang={lang} href={canonical} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://agentesva.com/" />
  </Fragment>
  <JsonLd slot="head" data={[localBusinessSchema, serviceSchema]} />

  <div class="dirA">
    <Header />

    <!-- HERO -->
    <section class="dirA-hero">
      <div class="container">
        <div style="max-width: 760px;">
          <span class="eyebrow">{industria.glyph} · Soluciones para {industria.nombre}</span>
          <h1 class="serif" style="margin-top: 16px;" set:html={industria.heroH1.replace(industria.nombre.split(' ')[0], `<em>${industria.nombre.split(' ')[0]}</em>`)} />
          <p class="dirA-hero-lede" style="margin-top: 16px;">{industria.heroLede}</p>
          <div class="dirA-hero-actions" style="margin-top: 24px;">
            <a class="btn btn-primary" href={CALENDLY_URL}>Reservar auditoría gratis →</a>
            <a class="btn btn-ghost" href="#beneficios">Ver beneficios</a>
          </div>
          <div class="dirA-hero-meta">
            <span class="dirA-hero-meta-dot"></span>
            <span>30 min sin coste · PDF personalizado en 24h</span>
          </div>
        </div>
      </div>
    </section>

    <!-- USE CASES -->
    <section id="beneficios" style="background: var(--paper); padding: 80px 0;">
      <div class="container">
        <div style="max-width: 720px; margin-bottom: 48px;">
          <span class="eyebrow">Casos de uso</span>
          <h2 class="serif" style="margin-top: 12px;">
            Tres formas de automatizar tu {industria.nombre.toLowerCase()} <em>esta semana</em>.
          </h2>
        </div>
        <div class="ind-uso-grid">
          {industria.usoCasos.map((c) => (
            <article class="ind-uso-card">
              <h3 class="serif">{c.titulo}</h3>
              <p>{c.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- RECOMMENDED AGENTS -->
    {recommendedAgents.length > 0 && (
      <section style="background: var(--paper-2); padding: 80px 0;">
        <div class="container">
          <div class="cat-meta" style="margin-bottom: 32px;">
            <div>
              <span class="eyebrow">Agentes recomendados</span>
              <h2 class="serif" style="margin-top: 8px; font-size: 32px;">Hechos para {industria.nombre.toLowerCase()}</h2>
            </div>
            <a href={catalogLink} class="btn btn-ghost">Ver todos los agentes →</a>
          </div>
          <div class="cat-grid">
            {recommendedAgents.map((a) => (
              <article class="cat-card">
                <div class="cat-card-thumb" style={`background:${a.gradient}`}>
                  <span class="cat-card-thumb-glyph">{a.icon}</span>
                </div>
                <div class="cat-card-body">
                  <h3 class="cat-card-title">{a.name}</h3>
                  <p class="cat-card-desc">{a.desc}</p>
                  <div class="cat-card-tags">
                    {(a.tags ?? []).slice(0, 3).map((t) => <span class="cat-tag">{t}</span>)}
                  </div>
                  <a href={CALENDLY_URL} class="btn btn-primary cat-card-cta">Consultar este agente</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- TESTIMONIAL -->
    <section style="background: var(--paper); padding: 80px 0;">
      <div class="container">
        <div class="ind-test">
          <div class="ind-test-stars">★★★★★</div>
          <blockquote class="serif">
            “{industria.testimonio.quote}”
          </blockquote>
          <div class="ind-test-by">
            <strong>{industria.testimonio.author}</strong> · {industria.testimonio.role}
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="dirA-cta">
      <div class="container">
        <div class="dirA-cta-card">
          <div>
            <h2 class="serif">{industria.ctaTitulo}</h2>
            <p>30 min de auditoría gratis. Salimos con tres oportunidades concretas para tu {industria.nombre.toLowerCase()}, priorizadas por ROI.</p>
          </div>
          <div class="dirA-cta-actions">
            <a class="btn btn-primary" href={CALENDLY_URL}>Reservar 30 min →</a>
            <a class="btn btn-ghost" href={catalogLink}>Ver agentes para {industria.nombre.toLowerCase()}</a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
    <MobileNav />
  </div>
</BaseLayout>

<style>
  .ind-uso-grid { display: grid; gap: 20px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .ind-uso-card { background: var(--card); border: 1px solid var(--line-soft); border-radius: 18px; padding: 28px; box-shadow: 0 1px 2px rgba(26,24,20,0.06); }
  .ind-uso-card h3 { font-size: 20px; margin: 0 0 12px; color: var(--ink); }
  .ind-uso-card p { color: var(--ink-3); margin: 0; line-height: 1.6; font-size: 14px; }

  .ind-test { max-width: 760px; margin: 0 auto; text-align: center; padding: 32px; }
  .ind-test-stars { color: var(--clay); font-size: 18px; letter-spacing: 4px; margin-bottom: 24px; }
  .ind-test blockquote { font-size: clamp(22px, 3vw, 30px); line-height: 1.35; color: var(--ink); margin: 0 0 24px; font-weight: 500; }
  .ind-test-by { color: var(--ink-3); font-size: 14px; }
  .ind-test-by strong { color: var(--ink); }

  /* Reuse cat- classes from main catalog page */
  .cat-grid { display: grid; gap: 24px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .cat-card { background: var(--card); border: 1px solid var(--line-soft); border-radius: 18px; overflow: hidden; box-shadow: 0 1px 2px rgba(26,24,20,0.06); display: flex; flex-direction: column; }
  .cat-card-thumb { position: relative; height: 140px; display: flex; align-items: center; justify-content: center; }
  .cat-card-thumb-glyph { font-size: 56px; }
  .cat-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
  .cat-card-title { font-weight: 600; font-size: 17px; line-height: 1.3; color: var(--ink); margin: 0; }
  .cat-card-desc { color: var(--ink-3); font-size: 13px; line-height: 1.5; margin: 0; }
  .cat-card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .cat-tag { padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 500; background: var(--paper-2); color: var(--ink-3); }
  .cat-card-cta { width: 100%; margin-top: auto; text-align: center; justify-content: center; }
  .cat-meta { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; flex-wrap: wrap; }
</style>
