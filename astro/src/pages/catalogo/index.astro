---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MobileNav from '../../components/MobileNav.astro';
import JsonLd from '../../components/JsonLd.astro';
import { agents, prompts, CALENDLY_URL } from '../../data/agents';

const sortedAgents = [...agents].sort((a, b) => {
  if ((a.prioridad ? 1 : 0) !== (b.prioridad ? 1 : 0)) return (b.prioridad ? 1 : 0) - (a.prioridad ? 1 : 0);
  if ((a.esNuevo ? 1 : 0) !== (b.esNuevo ? 1 : 0)) return (b.esNuevo ? 1 : 0) - (a.esNuevo ? 1 : 0);
  return (a.price ?? 0) - (b.price ?? 0);
});

const tierLabels: Record<string, string> = {
  gratis: 'Gratis',
  basico: 'Básico',
  estandar: 'Estándar',
  avanzado: 'Avanzado',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Catálogo de agentes IA AgentesVA',
  description: `${agents.length} agentes de automatización IA disponibles por industria`,
  numberOfItems: agents.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
};

const filterPills = [
  { id: 'todos', label: 'Todos' },
  { id: 'gratis', label: 'Gratis' },
  { id: 'basico', label: 'Básico' },
  { id: 'estandar', label: 'Estándar' },
  { id: 'avanzado', label: 'Avanzado' },
  { id: 'ind-Servicios', label: 'Servicios' },
  { id: 'ind-Ecommerce', label: 'Ecommerce' },
  { id: 'ind-SaaS', label: 'SaaS' },
  { id: 'ind-Agencia', label: 'Agencia' },
  { id: 'ind-Inmobiliaria', label: 'Inmobiliaria' },
];
---
<BaseLayout
  title={`Catálogo de ${agents.length} Agentes IA | AgentesVA`}
  description={`Explora ${agents.length} agentes IA y ${prompts.length} prompts para Make.com. Reserva una auditoría gratis y personalizamos el agente ideal para tu PyME.`}
  canonical="https://agentesva.com/catalogo/"
  ogImage="https://agentesva.com/assets/og-catalogo.png"
>
  <JsonLd slot="head" data={[itemListSchema]} />

  <div class="dirA">
    <Header />

    <section class="dirA-hero">
      <div class="container">
        <div style="max-width: 760px;">
          <span class="eyebrow">Catálogo · {agents.length} agentes + {prompts.length} prompts</span>
          <h1 class="serif" style="margin-top: 16px;">
            Agentes IA <em>listos para importar</em> en Make.com.
          </h1>
          <p class="dirA-hero-lede" style="margin-top: 16px;">
            {agents.length} agentes documentados por industria. Cada agente se personaliza en la auditoría gratis: en 30 minutos revisamos tu operación y diseñamos el flujo exacto que necesitas.
          </p>
          <div class="dirA-hero-actions" style="margin-top: 24px;">
            <a class="btn btn-primary" href={CALENDLY_URL}>Reservar auditoría gratis →</a>
            <a class="btn btn-ghost" href="#agentes-grid">Ver catálogo</a>
          </div>
        </div>
      </div>
    </section>

    <section style="background: var(--paper); padding: 48px 0 96px;">
      <div class="container">
        <div class="cat-controls">
          <input id="searchInput" type="text" placeholder="Buscar agentes…" class="cat-search" aria-label="Buscar agentes" />
          <div class="cat-pills" id="filterPills" role="tablist" aria-label="Filtrar por categoría">
            {filterPills.map((p) => (
              <button class={`cat-pill ${p.id === 'todos' ? 'is-active' : ''}`} data-filter={p.id} type="button">{p.label}</button>
            ))}
          </div>
        </div>

        <div class="cat-meta">
          <h2 class="serif cat-meta-title">Agentes IA</h2>
          <span id="agentCount" class="cat-meta-count">{agents.length} agentes</span>
        </div>

        <div class="cat-grid" id="agentes-grid">
          {sortedAgents.map((a) => {
            const tier = tierLabels[a.tier] ?? 'Básico';
            const tags = (a.tags ?? []).slice(0, 3);
            const industriaAttr = (a.industria ?? []).join('|');
            return (
              <article
                class="cat-card"
                data-id={a.id}
                data-tier={a.tier}
                data-free={a.free ? '1' : '0'}
                data-industria={industriaAttr}
                data-name={a.name.toLowerCase()}
                data-desc={a.desc.toLowerCase()}
              >
                <div class="cat-card-thumb" style={`background:${a.gradient}`}>
                  <span class="cat-card-thumb-glyph">{a.icon}</span>
                  {a.waitlist ? <span class="cat-badge cat-badge-soon">Próximamente</span> : a.esNuevo ? <span class="cat-badge cat-badge-new">Nuevo</span> : null}
                </div>
                <div class="cat-card-body">
                  <h3 class="cat-card-title">{a.name}</h3>
                  <p class="cat-card-desc">{a.desc}</p>
                  <div class="cat-card-tags">
                    {tags.map((t) => <span class="cat-tag">{t}</span>)}
                    <span class={`cat-tag cat-tag-tier cat-tier-${a.tier}`}>{tier}</span>
                  </div>
                  <button class="btn btn-primary cat-card-cta" type="button" data-open-agent={a.id}>
                    {a.waitlist ? 'Únete a la lista de espera' : 'Consultar este agente'}
                  </button>
                  <p class="cat-card-foot">{a.waitlist ? 'Te avisamos cuando esté listo' : 'Se personaliza en la auditoría gratis'}</p>
                </div>
              </article>
            );
          })}
        </div>

        <div class="cat-empty" id="catEmpty" hidden>
          <p>No encontramos agentes con esos filtros. <button type="button" id="clearFilters" class="cat-link">Limpiar filtros</button></p>
        </div>

        <div class="cat-cta-strip">
          <div>
            <h3 class="serif">Cada agente se personaliza en la auditoría gratis</h3>
            <p>No vendemos paquetes prearmados. En 30 minutos revisamos tu operación y diseñamos el agente exacto que necesitas.</p>
          </div>
          <a class="btn btn-primary" href={CALENDLY_URL}>Reservar auditoría gratis →</a>
        </div>
      </div>
    </section>

    <section style="background: var(--paper-2); padding: 64px 0 96px;">
      <div class="container">
        <div class="cat-meta">
          <h2 class="serif cat-meta-title">Prompts</h2>
          <span class="cat-meta-count">{prompts.length} prompts</span>
        </div>
        <div class="cat-grid" id="prompts-grid">
          {prompts.map((p) => (
            <article class="cat-card" data-prompt-id={p.id}>
              <div class="cat-card-thumb" style={`background:${p.gradient}`}>
                <span class="cat-card-thumb-glyph">{p.icon}</span>
              </div>
              <div class="cat-card-body">
                <span class="cat-tag">{p.cat}</span>
                <h3 class="cat-card-title" style="margin-top: 8px;">{p.name}</h3>
                <p class="cat-card-desc">{p.desc}</p>
                <div class="cat-card-tags">
                  {p.plat.map((pl) => <span class="cat-tag">{pl}</span>)}
                </div>
                <a href={CALENDLY_URL} class="btn btn-primary cat-card-cta">Ver Prompt</a>
                <p class="cat-card-foot">Te entregamos el prompt en la auditoría</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section style="background: var(--paper); padding: 80px 0;">
      <div class="container">
        <div class="cat-lead-card">
          <div>
            <span class="eyebrow">7 agentes gratis · descarga directa</span>
            <h2 class="serif" style="margin-top: 12px;">Recibe los 7 agentes gratis en tu correo</h2>
            <p>Blueprints listos para importar en Make.com + instrucciones paso a paso. Sin spam, sin tarjeta.</p>
          </div>
          <form id="catalog-lead-form" class="cat-lead-form">
            <input type="email" name="email" required placeholder="tu@email.com" autocomplete="email" />
            <button type="submit" class="btn btn-primary">Enviar gratis →</button>
          </form>
        </div>
      </div>
    </section>

    <section class="dirA-cta">
      <div class="container">
        <div class="dirA-cta-card">
          <div>
            <h2 class="serif">¿No encuentras lo que buscas?</h2>
            <p>Nuestro equipo construye soluciones a medida. Desde auditorías IA hasta implementación llave en mano.</p>
          </div>
          <div class="dirA-cta-actions">
            <a class="btn btn-primary" href="/servicios/">Hablar con un especialista →</a>
          </div>
        </div>
      </div>
    </section>

    <dialog id="agent-modal" class="cat-modal" aria-labelledby="modal-title">
      <div class="cat-modal-inner" id="modal-content">
        <div class="cat-modal-thumb" id="modalThumb">
          <span class="cat-modal-thumb-glyph" id="modalGlyph"></span>
          <button type="button" class="cat-modal-close" id="modalClose" aria-label="Cerrar">×</button>
        </div>
        <div class="cat-modal-body">
          <span class="cat-modal-eyebrow" id="modalSeg"></span>
          <h2 id="modal-title" class="cat-modal-title"></h2>
          <p class="cat-modal-hook" id="modalHook" hidden></p>
          <p class="cat-modal-desc" id="modalDesc"></p>
          <p class="cat-modal-desc" id="modalIdeal" hidden></p>
          <h4 id="modalIncludesLbl" hidden>Incluye</h4>
          <ul class="cat-modal-list" id="modalIncludes"></ul>
          <h4 id="modalTagsLbl" hidden>Plataformas</h4>
          <div class="cat-card-tags" id="modalTags" style="margin-bottom:0;"></div>
          <div class="cat-modal-action">
            <a id="modalCta" class="btn btn-primary" href={CALENDLY_URL} target="_blank" rel="noopener">Reservar auditoría gratis →</a>
            <p class="cat-modal-action-foot" id="modalFoot">En la auditoría revisamos tu caso y te mostramos cómo este agente se adapta a tu operación.</p>
          </div>
        </div>
      </div>
    </dialog>

    <Footer />
    <MobileNav />
  </div>
</BaseLayout>

<script id="agents-data" type="application/json" set:html={JSON.stringify(agents)}></script>

<style>
  .cat-controls { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
  .cat-search { width: 100%; padding: 14px 18px; border: 1px solid var(--line); border-radius: 14px; font-family: inherit; font-size: 15px; background: var(--card); color: var(--ink); }
  .cat-search:focus { outline: 2px solid var(--clay); outline-offset: 2px; }
  .cat-pills { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; }
  .cat-pill { flex-shrink: 0; padding: 8px 16px; border-radius: 999px; cursor: pointer; border: 1px solid var(--line); background: var(--card); color: var(--ink-2); font-family: inherit; font-size: 14px; font-weight: 500; transition: all 0.2s ease; white-space: nowrap; }
  .cat-pill:hover { background: var(--paper-2); }
  .cat-pill.is-active { background: var(--clay); color: #fff; border-color: var(--clay); }

  .cat-meta { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 24px; gap: 16px; flex-wrap: wrap; }
  .cat-meta-title { font-size: 28px; margin: 0; color: var(--ink); }
  .cat-meta-count { color: var(--ink-3); font-size: 14px; }

  .cat-grid { display: grid; gap: 24px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .cat-card { background: var(--card); border: 1px solid var(--line-soft); border-radius: 18px; overflow: hidden; box-shadow: 0 1px 2px rgba(26,24,20,0.06); transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; }
  .cat-card:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(26,24,20,0.08); }
  .cat-card[hidden] { display: none; }

  .cat-card-thumb { position: relative; height: 140px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .cat-card-thumb-glyph { font-size: 56px; line-height: 1; }
  .cat-badge { position: absolute; top: 10px; left: 10px; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .cat-badge-new { background: var(--sand); color: var(--ink); }
  .cat-badge-soon { background: var(--clay); color: #fff; }

  .cat-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
  .cat-card-title { font-weight: 600; font-size: 17px; line-height: 1.3; color: var(--ink); margin: 0; }
  .cat-card-desc { color: var(--ink-3); font-size: 13px; line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .cat-card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .cat-tag { padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 500; background: var(--paper-2); color: var(--ink-3); }
  .cat-tag-tier { font-weight: 700; }
  .cat-tier-gratis { background: var(--forest-wash); color: var(--forest); }
  .cat-tier-basico { background: var(--sand-wash); color: var(--ink-2); }
  .cat-tier-estandar { background: var(--clay-wash); color: var(--clay-deep); }
  .cat-tier-avanzado { background: var(--ink); color: var(--paper); }

  .cat-card-cta { width: 100%; margin-top: auto; }
  .cat-card-foot { color: var(--ink-3); font-size: 11px; text-align: center; margin: 4px 0 0; }

  .cat-empty { text-align: center; padding: 48px 16px; color: var(--ink-3); }
  .cat-link { background: none; border: none; color: var(--clay); cursor: pointer; text-decoration: underline; font: inherit; }

  .cat-cta-strip { margin-top: 64px; background: var(--card); border: 1px solid var(--line-soft); border-radius: 20px; padding: 32px; display: flex; gap: 24px; flex-wrap: wrap; align-items: center; justify-content: space-between; }
  .cat-cta-strip h3 { font-size: 22px; margin: 0 0 8px; color: var(--ink); }
  .cat-cta-strip p { color: var(--ink-3); margin: 0; max-width: 540px; }

  .cat-lead-card { background: var(--card); border: 1px solid var(--line-soft); border-radius: 24px; padding: 40px; display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center; }
  .cat-lead-card h2 { font-size: 28px; margin: 0 0 8px; color: var(--ink); }
  .cat-lead-card p { color: var(--ink-3); margin: 0; }
  .cat-lead-form { display: flex; gap: 8px; flex-wrap: wrap; }
  .cat-lead-form input { padding: 14px 16px; border: 1px solid var(--line); border-radius: 12px; font-family: inherit; font-size: 14px; min-width: 240px; }
  @media (max-width: 720px) { .cat-lead-card { grid-template-columns: 1fr; } }

  .cat-modal { border: none; border-radius: 20px; padding: 0; max-width: 540px; width: 95vw; max-height: 88vh; box-shadow: 0 24px 80px rgba(26,24,20,0.25); background: var(--card); color: var(--ink); overflow: hidden; }
  .cat-modal::backdrop { background: rgba(26,24,20,0.55); backdrop-filter: blur(4px); }
  .cat-modal-inner { max-height: 88vh; overflow-y: auto; }
  .cat-modal-thumb { position: relative; height: 120px; display: flex; align-items: center; justify-content: center; background: var(--clay); }
  .cat-modal-thumb-glyph { font-size: 64px; }
  .cat-modal-close { position: absolute; top: 12px; right: 12px; width: 36px; height: 36px; border-radius: 999px; border: none; background: rgba(255,255,255,0.25); color: #fff; cursor: pointer; font-size: 22px; line-height: 1; display: grid; place-items: center; }
  .cat-modal-close:hover { background: rgba(255,255,255,0.4); }
  .cat-modal-body { padding: 24px 28px 28px; }
  .cat-modal-eyebrow { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--ink-3); }
  .cat-modal-title { font-family: var(--font-serif, Fraunces); font-size: 24px; font-weight: 600; margin: 6px 0 12px; color: var(--ink); }
  .cat-modal-hook { color: var(--clay-deep); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .cat-modal-desc { color: var(--ink-2); margin: 0 0 16px; font-size: 14px; line-height: 1.6; }
  .cat-modal h4 { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin: 16px 0 8px; color: var(--ink-3); font-weight: 700; }
  .cat-modal-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .cat-modal-list li { font-size: 13px; color: var(--ink-2); padding-left: 20px; position: relative; }
  .cat-modal-list li::before { content: '✓'; position: absolute; left: 0; color: var(--forest); font-weight: 700; }
  .cat-modal-action { margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--line-soft); }
  .cat-modal-action .btn { width: 100%; text-align: center; justify-content: center; }
  .cat-modal-action-foot { text-align: center; font-size: 12px; color: var(--ink-3); margin-top: 10px; }
</style>

<script is:inline>
(function(){
  const grid = document.getElementById('agentes-grid');
  const cards = grid ? Array.from(grid.querySelectorAll('.cat-card')) : [];
  const pills = document.querySelectorAll('.cat-pill');
  const searchEl = document.getElementById('searchInput');
  const countEl = document.getElementById('agentCount');
  const emptyEl = document.getElementById('catEmpty');
  const clearBtn = document.getElementById('clearFilters');
  let currentFilter = 'todos';

  function applyFilters(){
    const q = (searchEl?.value || '').toLowerCase().trim();
    let visible = 0;
    cards.forEach((card) => {
      let match = true;
      if (currentFilter === 'gratis') match = card.dataset.free === '1';
      else if (['basico','estandar','avanzado'].includes(currentFilter)) match = card.dataset.tier === currentFilter;
      else if (currentFilter.startsWith('ind-')) {
        const ind = currentFilter.replace('ind-','');
        const inds = (card.dataset.industria || '').split('|');
        match = inds.includes(ind);
      }
      if (match && q) {
        match = (card.dataset.name || '').includes(q) || (card.dataset.desc || '').includes(q);
      }
      card.hidden = !match;
      if (match) visible++;
    });
    if (countEl) countEl.textContent = visible + ' agente' + (visible !== 1 ? 's' : '');
    if (emptyEl) emptyEl.hidden = visible !== 0;
  }
  function setFilter(filter){
    currentFilter = filter;
    pills.forEach((p) => p.classList.toggle('is-active', p.dataset.filter === filter));
    applyFilters();
  }
  pills.forEach((p) => p.addEventListener('click', () => setFilter(p.dataset.filter)));
  if (searchEl) {
    let t;
    searchEl.addEventListener('input', () => { clearTimeout(t); t = setTimeout(applyFilters, 200); });
  }
  if (clearBtn) clearBtn.addEventListener('click', () => { if (searchEl) searchEl.value=''; setFilter('todos'); });

  const urlFilter = new URLSearchParams(location.search).get('filter');
  if (urlFilter && document.querySelector('.cat-pill[data-filter="' + urlFilter + '"]')) setFilter(urlFilter);

  // Modal
  const modal = document.getElementById('agent-modal');
  const dataEl = document.getElementById('agents-data');
  const agentsForModal = dataEl ? JSON.parse(dataEl.textContent) : [];
  const elements = {
    thumb: document.getElementById('modalThumb'),
    glyph: document.getElementById('modalGlyph'),
    seg: document.getElementById('modalSeg'),
    title: document.getElementById('modal-title'),
    hook: document.getElementById('modalHook'),
    desc: document.getElementById('modalDesc'),
    ideal: document.getElementById('modalIdeal'),
    includesLbl: document.getElementById('modalIncludesLbl'),
    includes: document.getElementById('modalIncludes'),
    tagsLbl: document.getElementById('modalTagsLbl'),
    tags: document.getElementById('modalTags'),
    cta: document.getElementById('modalCta'),
    foot: document.getElementById('modalFoot'),
    close: document.getElementById('modalClose'),
  };

  function openAgentModal(id){
    const a = agentsForModal.find((x) => x.id === Number(id));
    if (!a || !modal) return;
    if (elements.thumb) elements.thumb.style.background = a.gradient;
    if (elements.glyph) elements.glyph.textContent = a.icon;
    if (elements.seg) elements.seg.textContent = a.seg || '';
    if (elements.title) elements.title.textContent = a.name;
    if (elements.hook) { elements.hook.textContent = a.hook || ''; elements.hook.hidden = !a.hook; }
    if (elements.desc) elements.desc.textContent = a.desc;
    if (elements.ideal) {
      if (a.idealPara) {
        elements.ideal.textContent = '';
        const strong = document.createElement('strong');
        strong.textContent = 'Ideal para: ';
        elements.ideal.appendChild(strong);
        elements.ideal.appendChild(document.createTextNode(a.idealPara));
        elements.ideal.hidden = false;
      } else { elements.ideal.hidden = true; }
    }
    if (elements.includes) {
      elements.includes.textContent = '';
      (a.includes || []).forEach((i) => {
        const li = document.createElement('li');
        li.textContent = i;
        elements.includes.appendChild(li);
      });
      const has = (a.includes || []).length > 0;
      elements.includesLbl.hidden = !has;
    }
    if (elements.tags) {
      elements.tags.textContent = '';
      (a.tags || []).forEach((t) => {
        const span = document.createElement('span');
        span.className = 'cat-tag';
        span.textContent = t;
        elements.tags.appendChild(span);
      });
      elements.tagsLbl.hidden = (a.tags || []).length === 0;
    }
    if (elements.cta) {
      elements.cta.textContent = a.waitlist ? 'Únete a la lista de espera →' : 'Reservar auditoría gratis →';
    }
    if (elements.foot) {
      elements.foot.textContent = a.waitlist
        ? 'Sin compromiso. Te avisamos por WhatsApp cuando esté en producción.'
        : 'En la auditoría revisamos tu caso y te mostramos cómo este agente se adapta a tu operación.';
    }
    if (typeof modal.showModal === 'function') modal.showModal();
    else modal.setAttribute('open','true');
    try {
      if (window.mixpanel) mixpanel.track('agent_viewed', { agent_id: a.id, agent_name: a.name, agent_tier: a.tier });
      if (window.gtag) gtag('event', 'agent_viewed', { agent_id: a.id, agent_name: a.name });
    } catch(e){}
  }

  if (elements.close) elements.close.addEventListener('click', () => modal && modal.close());
  document.addEventListener('click', (e) => {
    const trigger = e.target.closest('[data-open-agent]');
    if (trigger) { e.preventDefault(); openAgentModal(trigger.dataset.openAgent); }
  });
  if (modal) {
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  }

  const leadForm = document.getElementById('catalog-lead-form');
  if (leadForm) {
    leadForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = leadForm.querySelector('input[type="email"]').value;
      try {
        await fetch('/api/subscribe.php', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, product: 'free-bundle' })
        });
      } catch(_){}
      try { if (window.mixpanel) mixpanel.track('lead_captured', { source: 'catalog_banner' }); } catch(e){}
      window.location.href = '/gracias-gratis/?source=catalog';
    });
  }
})();
</script>
