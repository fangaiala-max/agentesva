---
// Carrusel 8 slides Pillar #1 - Kit Digital + Automatización con IA
// Dimensión por slide: 1080x1080 px (Instagram/LinkedIn feed)
// Para exportar: scroll cada slide, screenshot individual
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>Carrusel Kit Digital — AgentesVA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400&family=Inter+Tight:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --paper: #F7F3EC;
    --paper-2: #EFE8DC;
    --paper-3: #E5DCC8;
    --ink: #1A1814;
    --ink-2: #3D362C;
    --ink-3: #6B6253;
    --line-soft: #E8DFCC;
    --card: #FFFEFB;
    --clay: #C2543A;
    --clay-deep: #9C3F2A;
    --clay-soft: #E8B5A4;
    --clay-wash: #F4DDD2;
    --forest: #2F4A3A;
    --forest-wash: #DFE7E0;
    --sand: #E8C77E;
    --sand-wash: #F5E9CC;
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'Inter Tight', sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #2a2724; padding: 24px 0; font-family: var(--sans); color: var(--ink); }
  .stack { display: flex; flex-direction: column; align-items: center; gap: 24px; }
  .slide { width: 1080px; height: 1080px; padding: 80px; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; }
  .slide-num { font-family: var(--mono); font-size: 14px; letter-spacing: 0.16em; opacity: 0.6; }
  .slide-num strong { font-weight: 600; }
  .footer-strip { display: flex; justify-content: space-between; align-items: center; font-family: var(--mono); font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; }
  .accent-line { width: 56px; height: 4px; background: var(--clay); margin-bottom: 24px; }

  /* Common typography */
  .h1 { font-family: var(--serif); font-weight: 300; font-size: 96px; line-height: 0.95; letter-spacing: -0.04em; }
  .h1 em { font-style: italic; color: var(--clay); font-weight: 400; }
  .h1.dark em { color: var(--sand); }
  .h2 { font-family: var(--serif); font-weight: 400; font-size: 72px; line-height: 1.0; letter-spacing: -0.03em; }
  .h2 em { font-style: italic; color: var(--clay); }
  .h2.dark em { color: var(--sand); }
  .body { font-size: 28px; line-height: 1.4; color: var(--ink-3); max-width: 800px; }
  .body.dark { color: rgba(247,243,236,0.75); }
  .tag { font-family: var(--mono); font-size: 16px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--clay); font-weight: 600; }
  .tag.dark { color: var(--sand); }

  /* Logo */
  .logo { font-family: var(--serif); font-weight: 800; font-size: 28px; letter-spacing: -0.02em; }
  .logo-mark { display: inline-block; background: var(--ink); color: var(--paper); width: 36px; height: 36px; line-height: 36px; text-align: center; border-radius: 8px; font-style: italic; font-size: 22px; margin-right: 6px; vertical-align: middle; }
  .slide.dark .logo { color: var(--paper); }
  .slide.dark .logo-mark { background: var(--paper); color: var(--ink); }

  /* Backgrounds */
  .bg-paper { background: var(--paper); color: var(--ink); }
  .bg-paper-2 { background: var(--paper-2); color: var(--ink); }
  .bg-card { background: var(--card); color: var(--ink); }
  .bg-ink { background: var(--ink); color: var(--paper); }
  .bg-clay { background: var(--clay); color: var(--paper); }
  .bg-gradient { background: linear-gradient(135deg, var(--ink) 0%, var(--clay-deep) 100%); color: var(--paper); }

  /* Decorative */
  .decor-circle { position: absolute; border-radius: 50%; opacity: 0.15; pointer-events: none; }

  /* Slide 1 specific */
  .s1-amount { font-family: var(--serif); font-size: 280px; line-height: 0.85; letter-spacing: -0.05em; font-style: italic; font-weight: 400; color: var(--clay); margin: 0; }
  .s1-amount-bg { font-family: var(--serif); font-size: 380px; line-height: 0.8; color: var(--clay-wash); position: absolute; top: 200px; right: -40px; opacity: 0.5; pointer-events: none; user-select: none; font-weight: 200; }

  /* Lists */
  .list-item { display: flex; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--line-soft); align-items: start; }
  .list-item:last-child { border-bottom: 0; }
  .list-num { font-family: var(--serif); font-style: italic; color: var(--clay); font-size: 36px; line-height: 1; flex-shrink: 0; min-width: 48px; font-weight: 400; }
  .list-text { font-size: 26px; line-height: 1.35; color: var(--ink); font-weight: 500; }
  .list-text.dark { color: var(--paper); }
  .slide.dark .list-item { border-color: rgba(247,243,236,0.15); }
  .slide.dark .list-num { color: var(--sand); }

  /* Stats */
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-top: 1px solid currentColor; border-bottom: 1px solid currentColor; padding: 32px 0; }
  .stat-cell { padding: 16px 24px 16px 0; border-right: 1px solid currentColor; }
  .stat-cell:last-child { border-right: 0; }
  .stat-num { font-family: var(--serif); font-size: 96px; line-height: 0.9; letter-spacing: -0.03em; font-weight: 300; }
  .stat-num em { font-style: italic; color: var(--clay); }
  .stat-num.dark em { color: var(--sand); }
  .stat-label { font-family: var(--mono); font-size: 14px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.6; margin-top: 8px; }

  /* X / check icons */
  .icon-x { display: inline-grid; place-items: center; width: 36px; height: 36px; background: var(--clay-wash); color: var(--clay-deep); font-weight: 700; flex-shrink: 0; font-family: var(--sans); font-size: 18px; }
  .icon-check { display: inline-grid; place-items: center; width: 36px; height: 36px; background: var(--forest-wash); color: var(--forest); font-weight: 700; flex-shrink: 0; font-family: var(--sans); font-size: 18px; }

  /* CTA box */
  .cta-arrow { display: inline-block; font-family: var(--serif); font-style: italic; font-size: 80px; line-height: 1; color: var(--sand); }
</style>
</head>
<body>
<div class="stack">

<!-- ============= SLIDE 1: HOOK ============= -->
<section class="slide bg-paper">
  <div class="s1-amount-bg">€6k</div>
  <div style="position: relative;">
    <span class="slide-num"><strong>01</strong> / 08</span>
  </div>
  <div style="position: relative;">
    <div class="accent-line"></div>
    <span class="tag">Kit Digital · 2026</span>
    <h1 class="h1" style="margin-top: 24px;">El Estado le<br>regala a tu PyME<br><em>€6.000.</em></h1>
    <p class="body" style="margin-top: 32px; font-size: 32px; max-width: 700px;">La mayoría lo gasta en una nueva web que no convierte.<br><br>Te enseñamos a usarlo bien.</p>
  </div>
  <div class="footer-strip" style="position: relative;">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--clay);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 2: WHAT KIT DIGITAL COVERS ============= -->
<section class="slide bg-card">
  <div>
    <span class="slide-num"><strong>02</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag">Lo que cubre</span>
      <h2 class="h2" style="margin-top: 16px; font-size: 56px;">Kit Digital Segmento II<br>(<em>3-9 empleados</em>)</h2>
    </div>
  </div>
  <div>
    <div class="list-item">
      <span class="list-num">i</span>
      <div>
        <div class="list-text">Procesos</div>
        <div style="font-family: var(--mono); font-size: 18px; color: var(--clay); margin-top: 4px;">€6.000</div>
      </div>
    </div>
    <div class="list-item">
      <span class="list-num">ii</span>
      <div>
        <div class="list-text">Gestión de clientes (CRM)</div>
        <div style="font-family: var(--mono); font-size: 18px; color: var(--clay); margin-top: 4px;">€4.000</div>
      </div>
    </div>
    <div class="list-item">
      <span class="list-num">iii</span>
      <div>
        <div class="list-text">BI y analítica de datos</div>
        <div style="font-family: var(--mono); font-size: 18px; color: var(--clay); margin-top: 4px;">€4.000</div>
      </div>
    </div>
    <div class="list-item">
      <span class="list-num">iv</span>
      <div>
        <div class="list-text">Comunicaciones seguras</div>
        <div style="font-family: var(--mono); font-size: 18px; color: var(--clay); margin-top: 4px;">€125 / usuario</div>
      </div>
    </div>
  </div>
  <div class="footer-strip">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--clay);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 3: WHAT IT DOESN'T COVER ============= -->
<section class="slide bg-paper-2">
  <div>
    <span class="slide-num"><strong>03</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag">Errores comunes</span>
      <h2 class="h2" style="margin-top: 16px;">Lo que <em>NO</em> cubre.</h2>
    </div>
  </div>
  <div>
    <div class="list-item" style="border-color: var(--clay-soft);">
      <span class="icon-x">×</span>
      <span class="list-text">Suscripciones mensuales (Make.com, HubSpot mes a mes)</span>
    </div>
    <div class="list-item" style="border-color: var(--clay-soft);">
      <span class="icon-x">×</span>
      <span class="list-text">Hardware: ordenadores, móviles, infraestructura física</span>
    </div>
    <div class="list-item" style="border-color: var(--clay-soft);">
      <span class="icon-x">×</span>
      <span class="list-text">Categorías que ya tienes implementadas</span>
    </div>
    <div class="list-item" style="border-color: var(--clay-soft);">
      <span class="icon-x">×</span>
      <span class="list-text">Servicios sin Agente Digitalizador certificado</span>
    </div>
  </div>
  <div class="footer-strip">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--clay);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 4: CASE 1 RESTAURANTE ============= -->
<section class="slide bg-gradient dark">
  <div style="position: relative;">
    <span class="slide-num"><strong>04</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag dark">Caso real · Restaurante Cataluña</span>
      <h2 class="h2 dark" style="margin-top: 16px; color: var(--paper);">+60% facturación<br>en <em>4 meses.</em></h2>
    </div>
  </div>
  <div class="stat-grid" style="border-color: rgba(247,243,236,0.3);">
    <div class="stat-cell" style="border-color: rgba(247,243,236,0.3);">
      <div class="stat-num dark"><em>€25k</em></div>
      <div class="stat-label">Antes</div>
    </div>
    <div class="stat-cell" style="border-color: rgba(247,243,236,0.3);">
      <div class="stat-num dark"><em>€40k</em></div>
      <div class="stat-label">Después</div>
    </div>
  </div>
  <div>
    <p class="body dark" style="font-size: 24px;">WhatsApp Business con IA + integración OpenTable + recordatorios automáticos. <strong style="color: var(--sand);">Coste real al cliente: €0</strong> (cubierto por Kit Digital).</p>
  </div>
  <div class="footer-strip">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--sand);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 5: CASE 2 ESCUELA ============= -->
<section class="slide bg-paper">
  <div>
    <span class="slide-num"><strong>05</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag">Caso real · Escuela idiomas</span>
      <h2 class="h2" style="margin-top: 16px;">+60% alumnos<br>activos en <em>3 meses.</em></h2>
    </div>
  </div>
  <div class="stat-grid" style="border-color: var(--ink);">
    <div class="stat-cell" style="border-color: var(--ink);">
      <div class="stat-num"><em>500</em></div>
      <div class="stat-label" style="color: var(--ink);">Antes</div>
    </div>
    <div class="stat-cell">
      <div class="stat-num"><em>800</em></div>
      <div class="stat-label" style="color: var(--ink);">Ahora</div>
    </div>
  </div>
  <div>
    <p class="body" style="font-size: 24px;">Cadenas WhatsApp para recuperar dropouts del onboarding + tests de nivel automatizados. <strong style="color: var(--clay-deep);">Categorías Kit Digital: CRM €4.000 + Comunicaciones €500.</strong></p>
  </div>
  <div class="footer-strip">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--clay);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 6: CASE 3 RENTING ============= -->
<section class="slide bg-card">
  <div>
    <span class="slide-num"><strong>06</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag">Caso real · Renting B2B España</span>
      <h2 class="h2" style="margin-top: 16px;">+70% utilización<br>de flota en <em>2 meses.</em></h2>
    </div>
  </div>
  <div class="stat-grid" style="border-color: var(--ink);">
    <div class="stat-cell" style="border-color: var(--ink);">
      <div class="stat-num"><em>40</em>%</div>
      <div class="stat-label" style="color: var(--ink);">Antes</div>
    </div>
    <div class="stat-cell">
      <div class="stat-num"><em>68</em>%</div>
      <div class="stat-label" style="color: var(--ink);">Después</div>
    </div>
  </div>
  <div>
    <p class="body" style="font-size: 24px;">Agente IA perfila leads automáticamente y matchea con camión disponible más cercano. <strong style="color: var(--clay-deep);">Categoría Kit Digital: BI y analítica €4.000.</strong></p>
  </div>
  <div class="footer-strip">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--clay);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 7: 5 ERRORES ============= -->
<section class="slide bg-paper-2">
  <div>
    <span class="slide-num"><strong>07</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag">No te denieguen</span>
      <h2 class="h2" style="margin-top: 16px;">5 errores que<br><em>matan la subvención.</em></h2>
    </div>
  </div>
  <div>
    <div class="list-item">
      <span class="list-num">i</span>
      <span class="list-text" style="font-size: 24px;">Empresa sin alta CIRCE compatible</span>
    </div>
    <div class="list-item">
      <span class="list-num">ii</span>
      <span class="list-text" style="font-size: 24px;">Solicitar categorías que ya tienes</span>
    </div>
    <div class="list-item">
      <span class="list-num">iii</span>
      <span class="list-text" style="font-size: 24px;">Cambiar de Agente Digitalizador</span>
    </div>
    <div class="list-item">
      <span class="list-num">iv</span>
      <span class="list-text" style="font-size: 24px;">No justificar gasto en plazo (10 días)</span>
    </div>
    <div class="list-item">
      <span class="list-num">v</span>
      <span class="list-text" style="font-size: 24px;">Cerrar empresa antes de 24 meses</span>
    </div>
  </div>
  <div class="footer-strip">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--clay);">Desliza →</span>
  </div>
</section>

<!-- ============= SLIDE 8: CTA ============= -->
<section class="slide bg-ink dark">
  <div class="decor-circle" style="background: var(--clay); width: 480px; height: 480px; top: -120px; right: -120px; opacity: 0.25;"></div>
  <div style="position: relative;">
    <span class="slide-num" style="color: rgba(247,243,236,0.6);"><strong style="color: var(--paper);">08</strong> / 08</span>
    <div style="margin-top: 32px;">
      <span class="tag dark">Tu siguiente paso</span>
      <h1 class="h1 dark" style="margin-top: 24px; color: var(--paper);">Auditoría<br>gratis <em>30 min</em>.</h1>
    </div>
  </div>
  <div style="position: relative;">
    <p class="body dark" style="font-size: 28px; max-width: 800px;">Te decimos exactamente qué categorías Kit Digital aplican a tu PyME, qué automatizaciones encajan y cuánto pagarías de tu bolsillo.</p>
    <div style="margin-top: 48px; padding: 24px 32px; background: var(--clay); display: inline-block;">
      <span style="font-family: var(--serif); font-style: italic; font-size: 36px; font-weight: 400; color: var(--paper);">agentesva.com</span>
    </div>
  </div>
  <div class="footer-strip" style="position: relative; color: rgba(247,243,236,0.6);">
    <div class="logo"><span class="logo-mark">A</span>AgentesVA</div>
    <span style="color: var(--sand);">Link en bio →</span>
  </div>
</section>

</div>
</body>
</html>
