<style is:global>
.material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        font-family: 'Material Symbols Outlined';
        font-style: normal;
        display: inline-block;
        line-height: 1;
        text-transform: none;
        letter-spacing: normal;
        word-wrap: normal;
        white-space: nowrap;
        direction: ltr;
      }
</style>

<script is:inline>
function showDoc(id) {
    document.querySelectorAll('.legal-panel').forEach(function(p) { p.classList.add('hidden'); });
    document.querySelectorAll('.legal-tab').forEach(function(b) {
        b.className = 'legal-tab w-full text-left px-3 py-2 rounded-xl text-sm font-medium transition-all text-ink-3 hover:bg-paper-2 hover:text-ink';
    });
    var panel = document.getElementById('panel-' + id);
    if (panel) panel.classList.remove('hidden');
    var tab = document.getElementById('tab-' + id);
    if (tab) tab.className = 'legal-tab w-full text-left px-3 py-2 rounded-xl text-sm font-medium transition-all text-clay bg-ink/10 font-semibold';
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* Auto-activate from URL hash */
(function() {
    var hash = window.location.hash.replace('#', '');
    if (['privacidad','terminos','reembolso','whatsapp'].indexOf(hash) !== -1) {
        showDoc(hash);
    }
})();

var fyEl = document.getElementById('footer-year');
if (fyEl) fyEl.textContent = new Date().getFullYear();
</script>
