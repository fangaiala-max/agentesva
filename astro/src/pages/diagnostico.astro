---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';

const bodyHtml = `<!-- Main Content -->
<main class="pb-12 px-5 max-w-3xl mx-auto space-y-10">

    <!-- ==================== HERO ==================== -->
    <section class="text-center space-y-4 pt-8">
        <span class="inline-block px-3 py-1 rounded-full bg-paper-2 text-ink-2 text-xs font-semibold tracking-wide uppercase">Diagn&oacute;stico gratis</span>
        <h1 class="font-serif font-extrabold text-3xl md:text-5xl text-ink leading-tight">Descubre cu&aacute;nto te cuesta NO automatizar</h1>
        <p class="text-ink-3 text-lg max-w-2xl mx-auto">2 minutos &middot; 5 preguntas &middot; recibes diagn&oacute;stico personalizado gratis</p>
    </section>

    <!-- ==================== QUIZ ==================== -->
    <section id="quiz-wrapper" class="bg-card rounded-3xl border border-line-soft/10 p-6 md:p-10 space-y-6">

        <!-- Progress Bar -->
        <div id="progress-container" class="space-y-2">
            <div class="flex items-center justify-between text-xs font-semibold text-ink-3">
                <span id="progress-label">Pregunta 1 de 5</span>
                <span id="progress-percent">20%</span>
            </div>
            <div class="w-full bg-paper-2 rounded-full h-2 overflow-hidden">
                <div id="progress-bar" class="progress-bar-fill h-full bg-gradient-to-r from-ink to-clay rounded-full" style="width: 20%;"></div>
            </div>
        </div>

        <form id="quiz-form" action="#" method="post" novalidate>
            <!-- TODO: Replace action with real Make.com webhook once created -->

            <!-- Step 1: Tipo de negocio -->
            <div class="quiz-step active" data-step="1">
                <label class="block font-serif font-bold text-xl md:text-2xl text-ink mb-4">1. &iquest;Qu&eacute; tipo de negocio tienes?</label>
                <select name="tipo_negocio" id="q1" required class="w-full px-4 py-3 rounded-2xl border border-line-soft bg-paper text-ink focus:outline-none focus:border-ink">
                    <option value="">Selecciona tu sector...</option>
                    <option value="restaurante">Restaurante / Hosteler&iacute;a</option>
                    <option value="ecommerce">E-commerce / Tienda online</option>
                    <option value="servicios_profesionales">Servicios profesionales (abogado, consultor, coach)</option>
                    <option value="inmobiliaria">Inmobiliaria</option>
                    <option value="salud_belleza">Salud / Belleza / Cl&iacute;nica</option>
                    <option value="educacion">Educaci&oacute;n / Formaci&oacute;n</option>
                    <option value="b2b_servicios">B2B / Agencia / SaaS</option>
                    <option value="retail">Retail / Tienda f&iacute;sica</option>
                    <option value="otro">Otro</option>
                </select>
            </div>

            <!-- Step 2: Horas perdidas -->
            <div class="quiz-step" data-step="2">
                <label class="block font-serif font-bold text-xl md:text-2xl text-ink mb-4">2. &iquest;Cu&aacute;ntas horas/semana pierde tu equipo en tareas repetitivas?</label>
                <div class="space-y-2">
                    <div>
                        <input type="radio" name="horas_perdidas" id="h1" value="<5" class="hidden peer" required>
                        <label for="h1" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Menos de 5 horas</label>
                    </div>
                    <div>
                        <input type="radio" name="horas_perdidas" id="h2" value="5-10" class="hidden peer">
                        <label for="h2" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Entre 5 y 10 horas</label>
                    </div>
                    <div>
                        <input type="radio" name="horas_perdidas" id="h3" value="10-20" class="hidden peer">
                        <label for="h3" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Entre 10 y 20 horas</label>
                    </div>
                    <div>
                        <input type="radio" name="horas_perdidas" id="h4" value=">20" class="hidden peer">
                        <label for="h4" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">M&aacute;s de 20 horas (&iexcl;SOS!)</label>
                    </div>
                </div>
            </div>

            <!-- Step 3: No-shows / leads sin responder -->
            <div class="quiz-step" data-step="3">
                <label class="block font-serif font-bold text-xl md:text-2xl text-ink mb-4">3. &iquest;Cu&aacute;ntos leads o reservas se te escapan por no responder a tiempo?</label>
                <div class="space-y-2">
                    <div>
                        <input type="radio" name="leads_perdidos" id="l1" value="casi_ninguno" class="hidden peer" required>
                        <label for="l1" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Casi ninguno, respondemos r&aacute;pido</label>
                    </div>
                    <div>
                        <input type="radio" name="leads_perdidos" id="l2" value="algunos" class="hidden peer">
                        <label for="l2" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Algunos (10-25%)</label>
                    </div>
                    <div>
                        <input type="radio" name="leads_perdidos" id="l3" value="bastantes" class="hidden peer">
                        <label for="l3" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Bastantes (25-50%)</label>
                    </div>
                    <div>
                        <input type="radio" name="leads_perdidos" id="l4" value="muchos" class="hidden peer">
                        <label for="l4" class="radio-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Muchos (&gt;50%), me sangra el negocio</label>
                    </div>
                </div>
            </div>

            <!-- Step 4: Herramientas actuales -->
            <div class="quiz-step" data-step="4">
                <label class="block font-serif font-bold text-xl md:text-2xl text-ink mb-4">4. &iquest;Qu&eacute; herramientas usas hoy? <span class="text-sm font-normal text-ink-3">(marca todas las que apliquen)</span></label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                    <div><input type="checkbox" name="herramientas" id="t1" value="whatsapp" class="hidden peer"><label for="t1" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">WhatsApp Business</label></div>
                    <div><input type="checkbox" name="herramientas" id="t2" value="excel" class="hidden peer"><label for="t2" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Excel / Google Sheets</label></div>
                    <div><input type="checkbox" name="herramientas" id="t3" value="crm" class="hidden peer"><label for="t3" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">CRM (HubSpot, Pipedrive, etc.)</label></div>
                    <div><input type="checkbox" name="herramientas" id="t4" value="email" class="hidden peer"><label for="t4" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Email marketing (Mailchimp)</label></div>
                    <div><input type="checkbox" name="herramientas" id="t5" value="calendario" class="hidden peer"><label for="t5" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Calendario online (Calendly)</label></div>
                    <div><input type="checkbox" name="herramientas" id="t6" value="ecommerce_plat" class="hidden peer"><label for="t6" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Shopify / WooCommerce</label></div>
                    <div><input type="checkbox" name="herramientas" id="t7" value="zapier_make" class="hidden peer"><label for="t7" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Zapier / Make / n8n</label></div>
                    <div><input type="checkbox" name="herramientas" id="t8" value="ninguna" class="hidden peer"><label for="t8" class="check-label block px-4 py-3 rounded-2xl border border-line-soft cursor-pointer hover:bg-paper-2 transition">Ninguna / papel y tel&eacute;fono</label></div>
                </div>
            </div>

            <!-- Step 5: Frustración -->
            <div class="quiz-step" data-step="5">
                <label class="block font-serif font-bold text-xl md:text-2xl text-ink mb-4">5. &iquest;Cu&aacute;l es tu mayor frustraci&oacute;n operativa ahora mismo?</label>
                <textarea name="frustracion" id="q5" rows="4" required placeholder="Ej: respondo WhatsApp hasta las 11pm, se me pierden reservas, mi equipo copia datos a mano entre sistemas..." class="w-full px-4 py-3 rounded-2xl border border-line-soft bg-paper text-ink focus:outline-none focus:border-ink resize-none"></textarea>
            </div>

            <!-- Step 6: Email capture (final) -->
            <div class="quiz-step" data-step="6">
                <label class="block font-serif font-bold text-xl md:text-2xl text-ink mb-2">&iexcl;Listo! &iquest;A qu&eacute; email te env&iacute;o tu diagn&oacute;stico?</label>
                <p class="text-sm text-ink-3 mb-4">Recibir&aacute;s un par&aacute;grafo personalizado sobre qu&eacute; agentes encajar&iacute;an con tu negocio. Sin spam. Sin venta agresiva.</p>
                <input type="email" name="email" id="q6" required placeholder="tu@email.com" class="w-full px-4 py-3 rounded-2xl border border-line-soft bg-paper text-ink focus:outline-none focus:border-ink mb-3">
                <input type="text" name="nombre" id="q6b" placeholder="Tu nombre (opcional)" class="w-full px-4 py-3 rounded-2xl border border-line-soft bg-paper text-ink focus:outline-none focus:border-ink">
                <p class="text-[11px] text-ink-3 pt-3">Al enviar aceptas nuestra <a href="/legal/#privacidad" class="underline">pol&iacute;tica de privacidad</a>. Puedes darte de baja cuando quieras.</p>
            </div>

            <!-- Navigation -->
            <div class="flex items-center justify-between pt-6 mt-6 border-t border-line-soft/20">
                <button type="button" id="btn-back" class="px-5 py-3 text-clay font-bold rounded-full hover:bg-paper-2 transition-colors disabled:opacity-30 disabled:cursor-not-allowed" disabled>&larr; Atr&aacute;s</button>
                <button type="button" id="btn-next" class="px-8 py-3 bg-gradient-to-r from-ink to-clay text-paper font-bold rounded-full shadow-lg active:scale-95 transition-all">Siguiente &rarr;</button>
                <button type="submit" id="btn-submit" class="hidden px-8 py-3 bg-gradient-to-r from-ink to-clay text-paper font-bold rounded-full shadow-lg active:scale-95 transition-all">Recibir diagn&oacute;stico</button>
            </div>
        </form>
    </section>

    <!-- ==================== SUCCESS STATE ==================== -->
    <section id="success-state" class="hidden bg-gradient-to-br from-ink to-clay text-paper rounded-3xl p-8 md:p-12 text-center space-y-6">
        <span class="material-symbols-outlined text-6xl" style="font-variation-settings: 'FILL' 1;">mark_email_read</span>
        <h2 class="font-serif font-extrabold text-3xl md:text-4xl">&iexcl;Gracias! Hemos recibido tu diagn&oacute;stico.</h2>
        <p class="text-paper opacity-90 max-w-xl mx-auto">En las pr&oacute;ximas 24h nuestro personal revisar&aacute; tu caso personalmente y te enviar&aacute; un diagn&oacute;stico adaptado a tu negocio.</p>
        <div class="pt-4 space-y-3">
            <p class="text-sm opacity-90">&iquest;Quieres un an&aacute;lisis m&aacute;s profundo en vivo?</p>
            <a href="https://calendly.com/fangaiala/auditoria-gratis-agentesva-30-min" target="_blank" rel="noopener" class="inline-block px-8 py-4 bg-white text-clay font-black rounded-full shadow-xl active:scale-95 transition-all">Prefiero reservar auditor&iacute;a completa ahora &rarr;</a>
        </div>
    </section>

    <!-- ==================== TRUST ROW ==================== -->
    <section class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs md:text-sm text-ink-3 pt-2">
        <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base text-clay-deep">check_circle</span> Gratis</span>
        <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base text-clay-deep">check_circle</span> Sin compromiso</span>
        <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base text-clay-deep">check_circle</span> 2 minutos</span>
        <span class="inline-flex items-center gap-1"><span class="material-symbols-outlined text-base text-clay-deep">check_circle</span> PDF por email</span>
    </section>

</main>

<!-- Footer -->`;
---
<BaseLayout
  title={`Diagnóstico gratis de automatización en 2 min | AgentesVA`}
  description={`5 preguntas. Diagnóstico personalizado por email. Descubre cuánto te cuesta no automatizar tu PyME.`}
  canonical="https://agentesva.com/diagnostico/"
  ogImage="https://agentesva.com/assets/og-home.png"
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <link rel="alternate" hreflang="es" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="es-ES" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="es-MX" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="es-CO" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="es-AR" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="es-CL" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="es-PE" href="https://agentesva.com/diagnostico/" />
    <link rel="alternate" hreflang="x-default" href="https://agentesva.com/diagnostico/" />
    <script type="application/ld+json" is:inline set:html={`{"@context": "https://schema.org", "@type": "WebPage", "name": "Diagnóstico gratis de automatización en 2 min", "description": "5 preguntas para descubrir qué agentes IA encajan con tu negocio. Recibe diagnóstico personalizado por email.", "url": "https://agentesva.com/diagnostico/", "breadcrumb": {"@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://agentesva.com/"}, {"@type": "ListItem", "position": 2, "name": "Diagnóstico", "item": "https://agentesva.com/diagnostico/"}]}, "mainEntity": {"@type": "Service", "name": "Diagnóstico de automatización gratis", "serviceType": "Consultoría", "provider": {"@type": "Organization", "name": "AgentesVA"}, "areaServed": [{"@type": "Country", "name": "España"}, {"@type": "Country", "name": "México"}], "offers": {"@type": "Offer", "price": "0", "priceCurrency": "EUR"}}}`}></script>
  </Fragment>

  <Header />

  <Fragment set:html={bodyHtml} />

  <Footer />
  <MobileNav />
</BaseLayout>

<style is:global>
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
      body { min-height: max(884px, 100dvh); }
      .quiz-step { display: none; }
      .quiz-step.active { display: block; }
      .progress-bar-fill { transition: width 0.35s ease; }
      input[type="radio"]:checked + .radio-label,
      input[type="checkbox"]:checked + .check-label {
        border-color: rgb(var(--md-sys-color-primary, 0 48 198));
        background-color: rgb(var(--md-sys-color-primary-container, 30 71 241) / 0.08);
      }
</style>

<script is:inline>
(function() {
    // TODO: Replace with real Make.com webhook once created
    // HubSpot Forms API v3 — form "Diagnóstico AgentesVA"
    var HUBSPOT_PORTAL_ID = '148323903';
    var HUBSPOT_FORM_GUID = '6a283564-7cb8-46a6-a812-76101a686d41';
    var HUBSPOT_SUBMIT_URL = 'https://api.hsforms.com/submissions/v3/integration/submit/' + HUBSPOT_PORTAL_ID + '/' + HUBSPOT_FORM_GUID;

    // Map quiz → HubSpot enum values
    var HERRAMIENTAS_MAP = { whatsapp: 'whatsapp', excel: 'sheets', crm: 'crm', email: 'email', calendario: 'calendly', ecommerce_plat: 'otras', zapier_make: 'otras', ninguna: 'otras' };
    var STORAGE_KEY = 'agentesva_diagnostico_v1';
    var TOTAL_STEPS = 6;
    var currentStep = 1;
    var quizStartedTracked = false;

    var steps = document.querySelectorAll('.quiz-step');
    var btnNext = document.getElementById('btn-next');
    var btnBack = document.getElementById('btn-back');
    var btnSubmit = document.getElementById('btn-submit');
    var form = document.getElementById('quiz-form');
    var progressBar = document.getElementById('progress-bar');
    var progressLabel = document.getElementById('progress-label');
    var progressPercent = document.getElementById('progress-percent');

    function trackMixpanel(event, props) {
        try {
            if (window.mixpanel && typeof window.mixpanel.track === 'function') {
                window.mixpanel.track(event, props || {});
            }
        } catch (e) { /* noop */ }
    }

    function saveProgress() {
        try {
            var data = {};
            var fd = new FormData(form);
            fd.forEach(function(v, k) {
                if (data[k] !== undefined) {
                    if (!Array.isArray(data[k])) data[k] = [data[k]];
                    data[k].push(v);
                } else { data[k] = v; }
            });
            localStorage.setItem(STORAGE_KEY, JSON.stringify({ step: currentStep, data: data }));
        } catch (e) { /* noop */ }
    }

    function restoreProgress() {
        try {
            var raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return;
            var parsed = JSON.parse(raw);
            if (!parsed || !parsed.data) return;
            Object.keys(parsed.data).forEach(function(name) {
                var val = parsed.data[name];
                var vals = Array.isArray(val) ? val : [val];
                var fields = form.querySelectorAll('[name="' + name + '"]');
                fields.forEach(function(el) {
                    if (el.type === 'radio' || el.type === 'checkbox') {
                        if (vals.indexOf(el.value) !== -1) el.checked = true;
                    } else {
                        el.value = vals[0];
                    }
                });
            });
            if (parsed.step && parsed.step >= 1 && parsed.step <= TOTAL_STEPS) {
                currentStep = parsed.step;
            }
        } catch (e) { /* noop */ }
    }

    function validateStep(stepNum) {
        var step = document.querySelector('.quiz-step[data-step="' + stepNum + '"]');
        if (!step) return true;
        var required = step.querySelectorAll('[required]');
        for (var i = 0; i < required.length; i++) {
            var el = required[i];
            if (el.type === 'radio') {
                var group = step.querySelectorAll('[name="' + el.name + '"]');
                var checked = false;
                group.forEach(function(r) { if (r.checked) checked = true; });
                if (!checked) { alert('Por favor selecciona una opci\u00f3n para continuar.'); return false; }
                break;
            } else if (!el.value || !el.value.trim()) {
                el.focus();
                alert('Por favor completa este campo para continuar.');
                return false;
            } else if (el.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value)) {
                el.focus();
                alert('Por favor introduce un email v\u00e1lido.');
                return false;
            }
        }
        return true;
    }

    function showStep(n) {
        steps.forEach(function(s) { s.classList.remove('active'); });
        var target = document.querySelector('.quiz-step[data-step="' + n + '"]');
        if (target) target.classList.add('active');
        var pct = Math.round((n / TOTAL_STEPS) * 100);
        progressBar.style.width = pct + '%';
        progressLabel.textContent = 'Pregunta ' + n + ' de ' + TOTAL_STEPS;
        progressPercent.textContent = pct + '%';
        btnBack.disabled = (n === 1);
        if (n === TOTAL_STEPS) {
            btnNext.classList.add('hidden');
            btnSubmit.classList.remove('hidden');
        } else {
            btnNext.classList.remove('hidden');
            btnSubmit.classList.add('hidden');
        }
    }

    btnNext.addEventListener('click', function() {
        if (!quizStartedTracked) {
            trackMixpanel('quiz_started', { page: '/diagnostico/' });
            quizStartedTracked = true;
        }
        if (!validateStep(currentStep)) return;
        if (currentStep < TOTAL_STEPS) {
            currentStep++;
            showStep(currentStep);
            saveProgress();
            window.scrollTo({ top: document.getElementById('quiz-wrapper').offsetTop - 80, behavior: 'smooth' });
        }
    });

    btnBack.addEventListener('click', function() {
        if (currentStep > 1) {
            currentStep--;
            showStep(currentStep);
            saveProgress();
        }
    });

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!validateStep(currentStep)) return;
        saveProgress();

        btnSubmit.disabled = true;
        btnSubmit.textContent = 'Enviando...';

        var payload = {};
        var fd = new FormData(form);
        fd.forEach(function(v, k) {
            if (payload[k] !== undefined) {
                if (!Array.isArray(payload[k])) payload[k] = [payload[k]];
                payload[k].push(v);
            } else { payload[k] = v; }
        });
        payload.source = 'diagnostico_quiz';
        payload.url = window.location.href;
        payload.timestamp = new Date().toISOString();

        function done() {
            trackMixpanel('quiz_completed', { page: '/diagnostico/', tipo_negocio: payload.tipo_negocio });
            try { localStorage.removeItem(STORAGE_KEY); } catch(e) {}
            document.getElementById('quiz-wrapper').classList.add('hidden');
            document.getElementById('success-state').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Build HubSpot v3 Forms submission payload
        var herramientasArr = Array.isArray(payload.herramientas) ? payload.herramientas : (payload.herramientas ? [payload.herramientas] : []);
        var herramientasMapped = herramientasArr.map(function(v) { return HERRAMIENTAS_MAP[v] || 'otras'; });
        var dolorEnriched = (payload.frustracion || '') +
            '\n\n[Meta] Horas/semana perdidas: ' + (payload.horas_perdidas || 'n/a') +
            ' | Leads/clientes perdidos: ' + (payload.leads_perdidos || 'n/a');

        var hsPayload = {
            submittedAt: Date.now(),
            fields: [
                { objectTypeId: '0-1', name: 'firstname', value: payload.nombre || '' },
                { objectTypeId: '0-1', name: 'email', value: payload.email || '' },
                { objectTypeId: '0-1', name: 'industria_agentesva', value: payload.tipo_negocio || 'otro' },
                { objectTypeId: '0-1', name: 'herramientas_actuales', value: herramientasMapped.join(';') },
                { objectTypeId: '0-1', name: 'dolor_principal', value: dolorEnriched }
            ],
            context: {
                pageUri: window.location.href,
                pageName: document.title
            },
            legalConsentOptions: {
                consent: {
                    consentToProcess: true,
                    text: 'Acepto que AgentesVA procese mis datos para enviarme el diagnóstico personalizado.'
                }
            }
        };

        // Fire Make.com webhook for AI diagnostic email (fire-and-forget)
        fetch('https://hook.eu1.make.com/niwg4pqhrkk46ernjbwqang7n3iqvo8u', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).catch(function() { /* silent — email is a bonus, not a blocker */ });

        fetch(HUBSPOT_SUBMIT_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(hsPayload)
        }).then(function(res) {
            if (!res.ok) console.warn('HubSpot submit returned', res.status);
            done();
        }).catch(function() {
            // If network fails, still show success so user sees completion
            done();
        });
    });

    // Init
    restoreProgress();
    showStep(currentStep);
})();

/* FOOTER YEAR */
(function() {
    var el = document.getElementById('footer-year');
    if (el) el.textContent = new Date().getFullYear();
})();
</script>
