---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import MobileNav from '../../../components/MobileNav.astro';
import PostCard from '../../../components/PostCard.astro';
import JsonLd from '../../../components/JsonLd.astro';

const pillarMeta: Record<
  string,
  { label: string; title: string; description: string }
> = {
  'kit-digital': {
    label: 'Kit Digital',
    title: 'Kit Digital + automatización con IA',
    description:
      'Cómo cubrir automatización con IA con la subvención Kit Digital en España. Guías, casos reales y proceso paso a paso.',
  },
  'whatsapp-api': {
    label: 'WhatsApp Business API',
    title: 'WhatsApp Business API para PyMEs',
    description:
      'Implementación de WhatsApp Business API: plantillas, costes, integración con CRM, agentes IA y casos reales en España.',
  },
  'automatizacion-ia-pymes': {
    label: 'Automatización con IA',
    title: 'Automatización con IA para PyMEs',
    description:
      'Cómo automatizar procesos en PyMEs españolas con agentes IA, Make, Claude y stacks low-code. Tutoriales y aprendizajes.',
  },
  comparativas: {
    label: 'Comparativas',
    title: 'Comparativas de herramientas',
    description:
      'n8n vs Make vs Zapier, Claude vs GPT, plataformas de automatización: análisis honestos basados en uso real con clientes.',
  },
  'agentes-ia-concepto': {
    label: 'Agentes IA',
    title: 'Qué son los agentes IA',
    description:
      'Concepto, arquitectura y casos de uso de agentes IA aplicados a PyMEs y operaciones de negocio en España y LatAm.',
  },
  'caso-estudio': {
    label: 'Casos de estudio',
    title: 'Casos de estudio',
    description:
      'Casos reales de PyMEs que implementaron automatización con IA: stack, plazos, métricas, errores y aprendizajes.',
  },
};

export async function getStaticPaths() {
  return [
    { params: { pillar: 'kit-digital' } },
    { params: { pillar: 'whatsapp-api' } },
    { params: { pillar: 'automatizacion-ia-pymes' } },
    { params: { pillar: 'comparativas' } },
    { params: { pillar: 'agentes-ia-concepto' } },
    { params: { pillar: 'caso-estudio' } },
  ];
}

const { pillar } = Astro.params;
const meta = pillarMeta[pillar as string];
if (!meta) throw new Error(`Unknown pillar: ${pillar}`);

const isProd = import.meta.env.PROD;
const posts = await getCollection('blog', ({ data }) => {
  if (isProd && data.draft) return false;
  return data.pillar === pillar;
});
posts.sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

const url = `https://agentesva.com/blog/pillar/${pillar}/`;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://agentesva.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://agentesva.com/blog/' },
    { '@type': 'ListItem', position: 3, name: meta.label, item: url },
  ],
};
---
<BaseLayout
  title={`${meta.title} — AgentesVA Blog`}
  description={meta.description}
  canonical={url}
>
  <JsonLd slot="head" data={breadcrumbSchema} />
  <Header />
  <main class="bg-paper">
    <section class="container pt-16 md:pt-24 pb-12">
      <nav class="text-xs text-ink-3 mb-6" aria-label="Migas de pan">
        <a href="/" class="hover:text-clay transition">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/blog/" class="hover:text-clay transition">Blog</a>
        <span class="mx-2">/</span>
        <span>{meta.label}</span>
      </nav>
      <p class="eyebrow mb-4">Pilar editorial</p>
      <h1 class="font-serif text-5xl md:text-7xl leading-tight tracking-tight text-ink mb-6 max-w-4xl">
        {meta.title}
      </h1>
      <p class="text-lg md:text-xl text-ink-2 leading-relaxed max-w-2xl">{meta.description}</p>
    </section>

    <section class="container pb-24">
      {posts.length === 0 ? (
        <div class="py-16 text-center text-ink-3">
          <p class="text-lg">Aún no hay posts publicados en este pilar. Estamos escribiendo.</p>
          <a href="/blog/" class="inline-block mt-4 text-clay hover:text-clay-deep font-medium">← Volver al blog</a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((p) => (
            <PostCard
              href={`/blog/${p.slug}/`}
              title={p.data.title}
              description={p.data.description}
              pillar={p.data.pillar}
              publishedAt={p.data.publishedAt}
              readingTimeMin={p.data.readingTimeMin}
              author={p.data.author}
              ogImage={p.data.ogImage}
            />
          ))}
        </div>
      )}
    </section>
  </main>
  <Footer />
  <MobileNav />
</BaseLayout>
