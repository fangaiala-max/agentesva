---
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const isProd = import.meta.env.PROD;
  const posts = await getCollection('blog', ({ data }) => !(isProd && data.draft));
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await post.render();

// Compute reading time from word count if not explicitly set in frontmatter.
const wordCount = remarkPluginFrontmatter?.wordCount as number | undefined;
const computedReading =
  post.data.readingTimeMin ||
  (wordCount ? Math.max(2, Math.min(45, Math.round(wordCount / 220))) : undefined);

const frontmatter = {
  ...post.data,
  readingTimeMin: computedReading,
};
---
<BlogPostLayout frontmatter={frontmatter} slug={post.slug} headings={headings}>
  <Content />
</BlogPostLayout>
