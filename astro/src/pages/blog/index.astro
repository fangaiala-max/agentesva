---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MobileNav from '../../components/MobileNav.astro';
import PostCard from '../../components/PostCard.astro';
import JsonLd from '../../components/JsonLd.astro';
import EmailSignup from '../../components/EmailSignup.astro';

const isProd = import.meta.env.PROD;
const CALENDLY = 'https://calendly.com/fangaiala/auditoria-gratis-agentesva-30-min';

const all = await getCollection('blog', ({ data }) => !(isProd && data.draft));
all.sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

const featured = all.find((p) => p.data.featured) ?? all[0];
const rest = all.filter((p) => p.id !== featured?.id);

const pillars = [
  { slug: 'todos', label: 'Todos' },
  { slug: 'kit-digital', label: 'Kit Digital' },
  { slug: 'whatsapp-api', label: 'WhatsApp API' },
  { slug: 'automatizacion-ia-pymes', label: 'Automatización IA' },
  { slug: 'comparativas', label: 'Comparativas' },
  { slug: 'agentes-ia-concepto', label: 'Agentes IA' },
  { slug: 'caso-estudio', label: 'Casos' },
];

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'AgentesVA Blog',
  description:
    'Tutoriales técnicos, casos reales y análisis del mercado español de automatización con IA para PyMEs.',
  url: 'https://agentesva.com/blog/',
  publisher: { '@type': 'Organization', name: 'AgentesVA' },
  blogPost: all.slice(0, 10).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    url: `https://agentesva.com/blog/${p.slug}/`,
    datePublished: new Date(p.data.publishedAt).toISOString(),
  })),
};
---
<BaseLayout
  title="Blog — AgentesVA"
  description="Tutoriales técnicos, casos reales y análisis del mercado español de automatización con IA para PyMEs. Kit Digital, WhatsApp API, Make, n8n y agentes IA."
  canonical="https://agentesva.com/blog/"
>
  <JsonLd slot="head" data={blogSchema} />
  <link slot="head" rel="alternate" type="application/rss+xml" title="AgentesVA Blog RSS" href="/rss.xml" />

  <Header />

  <main class="bg-paper">
    <div class="max-w-screen-md mx-auto px-5 md:px-8">

      <!-- Hero del blog -->
      <section class="pt-12 md:pt-20 pb-8 text-center">
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3 mb-4">El blog · AgentesVA</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-normal tracking-tight text-ink leading-[1.05] mb-5">
          Notas sobre <em class="italic text-clay">automatización con IA</em> para PyMEs
        </h1>
        <p class="text-base md:text-lg text-ink-2 leading-relaxed max-w-xl mx-auto">
          Tutoriales técnicos, casos reales y análisis del mercado español. Kit Digital, WhatsApp API, comparativas de stack y aprendizajes de implementación.
        </p>
      </section>

      <!-- Filtros por pilar -->
      <section class="pb-10 -mx-5 md:mx-0 px-5 md:px-0 overflow-x-auto">
        <div class="flex gap-2 min-w-max md:flex-wrap md:min-w-0" role="tablist" aria-label="Filtrar por pilar">
          {pillars.map((p) => (
            <button
              type="button"
              class="js-pillar-filter shrink-0 px-4 py-2 rounded-full border border-line bg-card text-ink-2 text-sm font-medium hover:bg-paper-2 hover:border-clay/30 transition data-[active=true]:bg-ink data-[active=true]:text-paper data-[active=true]:border-ink"
              data-pillar={p.slug}
              data-active={p.slug === 'todos' ? 'true' : 'false'}
            >
              {p.label}
            </button>
          ))}
        </div>
      </section>

      <!-- Featured Post -->
      {featured && (
        <section class="pb-10">
          <div class="post-card-wrap" data-pillar={featured.data.pillar}>
            <PostCard
              href={`/blog/${featured.slug}/`}
              title={featured.data.title}
              description={featured.data.description}
              pillar={featured.data.pillar}
              publishedAt={featured.data.publishedAt}
              readingTimeMin={featured.data.readingTimeMin}
              author={featured.data.author}
              variant="featured"
            />
          </div>
        </section>
      )}

      <!-- Divider -->
      <div class="h-px bg-line opacity-50 w-full"></div>

      <!-- Newsletter signup -->
      <section class="py-10 border-t border-line/40">
        <EmailSignup
          list="newsletter"
          variant="card"
          eyebrow="Newsletter · 1 email cada 2 semanas"
          title="Recibe los próximos artículos en tu bandeja"
          description="Tutoriales, casos reales y aprendizajes de implementación de automatización con IA para PyMEs. Sin promesas mágicas, solo lo que funciona."
          placeholder="tu@email.com"
          ctaLabel="Suscribirme"
          privacyNote="Sin spam. Cancelas cuando quieras. Cumple RGPD."
        />
      </section>

      <!-- Latest Dispatches -->
      <section class="py-10">
        <div class="flex items-baseline justify-between mb-4">
          <h3 class="font-serif text-2xl md:text-3xl font-normal text-ink">Últimas publicaciones</h3>
          <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-3">{rest.length} artículos</span>
        </div>
        {rest.length === 0 && !featured && (
          <div class="py-20 text-center text-ink-3">
            <p class="text-lg">Aún no hay posts publicados. Vuelve pronto.</p>
          </div>
        )}
        <div class="js-post-grid">
          {rest.map((p) => (
            <div class="post-card-wrap" data-pillar={p.data.pillar}>
              <PostCard
                href={`/blog/${p.slug}/`}
                title={p.data.title}
                description={p.data.description}
                pillar={p.data.pillar}
                publishedAt={p.data.publishedAt}
                readingTimeMin={p.data.readingTimeMin}
                author={p.data.author}
                variant="compact"
              />
            </div>
          ))}
        </div>
      </section>

    </div>

    <!-- CTA Auditoría gratis -->
    <section class="bg-ink text-paper py-16 md:py-20 px-6 my-8">
      <div class="max-w-screen-md mx-auto flex flex-col items-center text-center gap-6">
        <div class="w-12 h-px bg-clay"></div>
        <h2 class="font-serif text-3xl md:text-4xl font-normal leading-tight">
          Mejora tu operación <em class="italic text-sand">sin contratar más personal</em>.
        </h2>
        <p class="text-base text-paper/80 max-w-md leading-relaxed">
          Auditoría gratis de 30 min + PDF personalizado en 24h con tus top 3 automatizaciones priorizadas por ROI.
        </p>
        <a
          href={CALENDLY}
          target="_blank"
          rel="noopener"
          class="inline-block bg-paper hover:bg-sand text-ink font-mono text-[11px] uppercase tracking-[0.18em] px-8 py-4 transition-all duration-300 rounded-full font-semibold"
        >
          Reservar auditoría gratis
        </a>
        <div class="w-12 h-px bg-clay"></div>
      </div>
    </section>
  </main>

  <Footer />
  <MobileNav />
</BaseLayout>

<script is:inline>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const initial = params.get('pillar') || 'todos';
    const buttons = document.querySelectorAll('.js-pillar-filter');
    const wraps = document.querySelectorAll('.post-card-wrap');

    function apply(pillar) {
      buttons.forEach((b) => b.setAttribute('data-active', b.getAttribute('data-pillar') === pillar ? 'true' : 'false'));
      wraps.forEach((w) => {
        const wp = w.getAttribute('data-pillar');
        w.style.display = pillar === 'todos' || pillar === wp ? '' : 'none';
      });
    }

    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        const p = b.getAttribute('data-pillar');
        apply(p);
        const u = new URL(window.location.href);
        if (p === 'todos') u.searchParams.delete('pillar');
        else u.searchParams.set('pillar', p);
        history.replaceState({}, '', u.toString());
      });
    });

    apply(initial);
  })();
</script>
