---
export interface Props {
  eyebrow?: string;
  title?: string;
  before: string[];
  after: string[];
  beforeTag?: string;
  afterTag?: string;
}
const {
  eyebrow = 'Antes & Después',
  title = 'Esto es lo que cambia <em>cuando automatizas</em>.',
  before,
  after,
  beforeTag = 'Antes',
  afterTag = 'Después',
} = Astro.props;

const len = Math.min(before.length, after.length);
const pairs = Array.from({ length: len }, (_, i) => ({
  index: i + 1,
  before: before[i],
  after: after[i],
}));
const pad2 = (n: number) => String(n).padStart(2, '0');
---
<section class="dirA-ba ba-v2">
  <div class="container">
    <div class="dirA-ba-head">
      <span class="dirA-eyebrow on-clay">{eyebrow}</span>
      <h2 class="serif" set:html={title} />
      <p class="ba-v2-lede">
        Cada fricción operativa tiene una contrapartida automatizable. Pasa el cursor sobre cualquier par para ver la transformación.
      </p>
      <div class="ba-v2-toggle" role="tablist" aria-label="Cambiar vista">
        <button type="button" class="ba-v2-toggle-btn is-active" data-view="all">Ambos</button>
        <button type="button" class="ba-v2-toggle-btn" data-view="before">{beforeTag}</button>
        <button type="button" class="ba-v2-toggle-btn" data-view="after">{afterTag}</button>
      </div>
    </div>

    <div class="ba-v2-cols-head" aria-hidden="true">
      <div class="ba-v2-col-label ba-v2-col-before">
        <span class="ba-v2-col-dot ba-v2-dot-before"></span>
        <span>{beforeTag}</span>
      </div>
      <div class="ba-v2-col-arrow"></div>
      <div class="ba-v2-col-label ba-v2-col-after">
        <span class="ba-v2-col-dot ba-v2-dot-after"></span>
        <span>{afterTag}</span>
      </div>
    </div>

    <div class="ba-v2-pairs">
      {pairs.map((pair) => (
        <article class="ba-v2-pair av-reveal" data-pair={pair.index}>
          <div class="ba-v2-num" aria-hidden="true">{pad2(pair.index)}</div>

          <div class="ba-v2-side ba-v2-before">
            <div class="ba-v2-glyph ba-v2-glyph-before" aria-label={beforeTag}>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="6" y1="12" x2="18" y2="12" />
              </svg>
            </div>
            <p class="ba-v2-text">{pair.before}</p>
          </div>

          <div class="ba-v2-bridge" aria-hidden="true">
            <svg class="ba-v2-bridge-svg" viewBox="0 0 80 24" preserveAspectRatio="none">
              <line x1="0" y1="12" x2="68" y2="12" stroke="currentColor" stroke-width="1" stroke-dasharray="3 4" class="ba-v2-bridge-line" />
              <polyline points="60,6 70,12 60,18" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" class="ba-v2-bridge-arrow" />
            </svg>
          </div>

          <div class="ba-v2-side ba-v2-after">
            <div class="ba-v2-glyph ba-v2-glyph-after" aria-label={afterTag}>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="5,12 10,17 19,7" />
              </svg>
            </div>
            <p class="ba-v2-text">{pair.after}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ba-v2 { padding: 96px 0; background: var(--paper-2); }
  .ba-v2 .dirA-ba-head { text-align: center; margin-bottom: 48px; max-width: 780px; margin-left: auto; margin-right: auto; }
  .ba-v2 .dirA-ba-head h2 { max-width: 720px; margin: 16px auto 16px; }
  .ba-v2-lede { color: var(--ink-3); font-size: 16px; line-height: 1.55; max-width: 580px; margin: 0 auto; }

  .ba-v2-toggle {
    display: none; margin-top: 24px;
    background: var(--card); border: 1px solid var(--line);
    border-radius: 999px; padding: 4px; gap: 4px;
    width: fit-content; margin-left: auto; margin-right: auto;
  }
  .ba-v2-toggle-btn {
    background: transparent; border: none;
    padding: 8px 16px; border-radius: 999px;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-3); cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .ba-v2-toggle-btn.is-active { background: var(--ink); color: var(--paper); }

  .ba-v2-cols-head {
    display: grid; grid-template-columns: 56px 1fr 88px 1fr;
    align-items: center; gap: 16px;
    padding: 0 4px 12px; border-bottom: 1px solid var(--line);
    margin-bottom: 8px;
  }
  .ba-v2-cols-head > :first-child { display: none; }
  .ba-v2-col-label {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--mono); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-3); font-weight: 600;
  }
  .ba-v2-col-before { grid-column: 2; }
  .ba-v2-col-after  { grid-column: 4; }
  .ba-v2-col-arrow  { grid-column: 3; }
  .ba-v2-col-dot { width: 8px; height: 8px; border-radius: 50%; }
  .ba-v2-dot-before { background: var(--clay); box-shadow: 0 0 0 4px var(--clay-wash); }
  .ba-v2-dot-after  { background: var(--forest); box-shadow: 0 0 0 4px var(--forest-wash); }

  .ba-v2-pairs { display: flex; flex-direction: column; gap: 6px; }
  .ba-v2-pair {
    display: grid; grid-template-columns: 56px 1fr 88px 1fr;
    align-items: stretch; gap: 16px;
    padding: 18px 4px;
    border-bottom: 1px dashed var(--line);
    transition: background 0.25s ease;
    position: relative;
  }
  .ba-v2-pair:last-child { border-bottom: 0; }
  .ba-v2-pair:hover { background: rgba(255,254,251,0.7); border-radius: 8px; }
  .ba-v2-pair:hover .ba-v2-bridge-line { stroke-dasharray: 1 0; opacity: 1; }
  .ba-v2-pair:hover .ba-v2-bridge-arrow { transform: translateX(4px); }
  .ba-v2-pair:hover .ba-v2-glyph { transform: scale(1.1); }

  .ba-v2-num {
    font-family: var(--serif); font-style: italic;
    font-size: 32px; color: var(--clay);
    align-self: center; text-align: center;
    line-height: 1; letter-spacing: -0.03em; font-weight: 400;
  }

  .ba-v2-side {
    display: flex; gap: 12px; align-items: flex-start;
    padding: 12px 16px;
    border-radius: var(--r-md);
    background: var(--card);
    border: 1px solid var(--line-soft);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .ba-v2-pair:hover .ba-v2-before { border-color: var(--clay-soft); box-shadow: 0 1px 0 var(--clay-soft); }
  .ba-v2-pair:hover .ba-v2-after  { border-color: var(--forest-soft); box-shadow: 0 1px 0 var(--forest-soft); }

  .ba-v2-glyph {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
    display: grid; place-items: center;
    transition: transform 0.25s ease;
  }
  .ba-v2-glyph-before { background: var(--clay-wash); color: var(--clay-deep); }
  .ba-v2-glyph-after  { background: var(--forest-wash); color: var(--forest); }

  .ba-v2-text {
    margin: 0; font-size: 15px; line-height: 1.45;
    color: var(--ink-2); align-self: center;
  }

  .ba-v2-bridge {
    color: var(--ink-4);
    display: flex; align-items: center; justify-content: center;
    transition: color 0.25s ease;
  }
  .ba-v2-pair:hover .ba-v2-bridge { color: var(--clay); }
  .ba-v2-bridge-svg { width: 100%; max-width: 80px; height: 24px; overflow: visible; }
  .ba-v2-bridge-line { transition: opacity 0.3s ease, stroke-dasharray 0.3s ease; }
  .ba-v2-bridge-arrow { transition: transform 0.3s ease; }

  .ba-v2-pairs.view-before .ba-v2-after,
  .ba-v2-pairs.view-before .ba-v2-bridge { opacity: 0.25; }
  .ba-v2-pairs.view-after .ba-v2-before,
  .ba-v2-pairs.view-after .ba-v2-bridge { opacity: 0.25; }

  @media (max-width: 760px) {
    .ba-v2 { padding: 64px 0; }
    .ba-v2-toggle { display: inline-flex; }
    .ba-v2-cols-head { display: none; }
    .ba-v2-pair {
      grid-template-columns: 40px 1fr;
      grid-template-rows: auto auto auto;
      gap: 8px 12px; padding: 16px 0;
    }
    .ba-v2-num {
      grid-column: 1; grid-row: 1 / span 3;
      font-size: 24px;
    }
    .ba-v2-before { grid-column: 2; grid-row: 1; }
    .ba-v2-bridge {
      grid-column: 2; grid-row: 2;
      justify-content: flex-start;
      padding: 4px 12px;
    }
    .ba-v2-bridge-svg {
      width: 24px; height: 24px;
      transform: rotate(90deg);
      transform-origin: center;
    }
    .ba-v2-after  { grid-column: 2; grid-row: 3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ba-v2-pair, .ba-v2-side, .ba-v2-glyph, .ba-v2-bridge,
    .ba-v2-bridge-line, .ba-v2-bridge-arrow { transition: none !important; }
  }
</style>

<script is:inline>
  (function () {
    const buttons = document.querySelectorAll('.ba-v2-toggle-btn');
    const pairsContainer = document.querySelector('.ba-v2-pairs');
    if (!buttons.length || !pairsContainer) return;
    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        buttons.forEach((x) => x.classList.toggle('is-active', x === b));
        pairsContainer.classList.remove('view-before', 'view-after');
        const v = b.getAttribute('data-view');
        if (v === 'before') pairsContainer.classList.add('view-before');
        if (v === 'after')  pairsContainer.classList.add('view-after');
      });
    });
  })();
</script>
