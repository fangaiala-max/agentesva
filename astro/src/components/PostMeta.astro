---
export interface Props {
  publishedAt: Date;
  readingTimeMin?: number;
  author?: string;
  tags?: string[];
  compact?: boolean;
}

const { publishedAt, readingTimeMin, author, tags = [], compact = false } = Astro.props;

const dateStr = new Date(publishedAt).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<div class={`flex flex-wrap items-center gap-x-3 gap-y-2 text-ink-3 ${compact ? 'text-xs' : 'text-sm'}`}>
  <time datetime={new Date(publishedAt).toISOString()}>{dateStr}</time>
  {readingTimeMin && (
    <>
      <span aria-hidden="true">·</span>
      <span>{readingTimeMin} min de lectura</span>
    </>
  )}
  {author && (
    <>
      <span aria-hidden="true">·</span>
      <span>{author}</span>
    </>
  )}
  {!compact && tags.length > 0 && (
    <div class="flex flex-wrap gap-2 ml-auto">
      {tags.slice(0, 3).map((t) => (
        <a href={`/blog/tag/${t}/`} class="px-2.5 py-0.5 rounded-full bg-paper-2 text-ink-2 text-xs hover:bg-clay-wash hover:text-clay-deep transition">
          #{t}
        </a>
      ))}
    </div>
  )}
</div>
