---
export interface Step {
  roman: string;
  when: string;
  title: string;
  desc: string;
}
export interface Props {
  eyebrow?: string;
  title?: string;
  steps: Step[];
  id?: string;
}
const {
  eyebrow = 'Cómo trabajamos',
  title = 'De auditoría a operación, <em>en cuatro pasos claros</em>.',
  steps,
  id = 'proc',
} = Astro.props;
---
<section class="dirA-proc" id={id}>
  <div class="container">
    <div class="dirA-proc-head">
      <span class="dirA-eyebrow on-clay">{eyebrow}</span>
      <h2 class="serif" set:html={title} />
    </div>
    <div class="dirA-proc-steps">
      <div class="dirA-proc-line" aria-hidden="true"></div>
      {steps.map((s) => (
        <div class="dirA-proc-step">
          <div class="dirA-proc-circle">{s.roman}</div>
          <div class="dirA-proc-when">{s.when}</div>
          <div class="dirA-proc-title">{s.title}</div>
          <p class="dirA-proc-desc" set:html={s.desc} />
        </div>
      ))}
    </div>
  </div>
</section>
