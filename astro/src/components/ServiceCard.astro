---
export interface Props {
  num: string;
  title: string;
  desc: string;
  tags: string[];
  comingSoon?: boolean;
  comingSoonHref?: string;
}
const { num, title, desc, tags, comingSoon = false } = Astro.props;
---
<article class="dirA-srv-item">
  <div class="dirA-srv-num">
    {num}
    {comingSoon && (
      <>
        {' · '}<span style="color: var(--sand);">Próximamente</span>
      </>
    )}
  </div>
  <h3 class="dirA-srv-title">{title}</h3>
  <p class="dirA-srv-desc" set:html={desc} />
  <div class="dirA-srv-tags">
    {tags.map((t) => <span class="dirA-srv-tag">{t}</span>)}
  </div>
</article>
