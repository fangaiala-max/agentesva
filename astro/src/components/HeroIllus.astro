---
export interface Props {
  mark?: string;
  quote?: string;
  label?: string;
}
const {
  mark = 'A',
  quote = 'Automatizamos lo que repites. Tú dedicas tiempo a lo que importa.',
  label = 'Auditoría gratis · 30 min',
} = Astro.props;
---
<div class="dirA-hero-illus">
  <div class="dirA-hero-illus-stamp">
    <span class="dirA-hero-illus-stamp-dot"></span>
    Activo
  </div>
  <div class="dirA-hero-illus-mark">{mark}</div>
  <div class="dirA-hero-illus-label">{label}</div>
  <p class="dirA-hero-illus-quote">{quote}</p>
</div>
