---
import '../styles/global.css';
import '@fontsource/dm-serif-display/400.css';
import '@fontsource/dm-serif-display/400-italic.css';
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/jetbrains-mono';
import { ClientRouter } from 'astro:transitions';
import { entityGraph, jsonLdSerialize, SITE } from '../data/schema';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}
const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, SITE).href,
  ogImage = `${SITE}/og.png`,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow" />
      )
    }
    <meta name="geo.placename" content="España" />
    <meta name="geo.region" content="ES" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="AgentesVA — IA en español" href="/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="AgentesVA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={jsonLdSerialize(entityGraph)} />
    <ClientRouter />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
