---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AgentesVA — Directorio de herramientas de IA en español"
  description="El directorio y medio de inteligencia artificial en español. Descubre, compara y aprende a usar las mejores herramientas de IA para tu negocio. En construcción."
>
  <main class="mx-auto flex min-h-screen max-w-3xl flex-col justify-center px-6 py-20">
    <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-emerald-400">
      En construcción · Fase 0
    </p>
    <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-6xl">
      AgentesVA
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
      El <strong class="text-white"
        >directorio y medio de inteligencia artificial en español</strong
      >. Descubre, compara y aprende a usar las mejores herramientas de IA para
      tu negocio.
    </p>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-400">
      Estamos construyendo la plataforma. Pronto: directorio de herramientas,
      cursos, noticias y newsletter — en español, para España y Latinoamérica.
    </p>
    <footer class="mt-16 border-t border-slate-800 pt-6 text-sm text-slate-500">
      © 2026 AgentesVA · Hecho en español para España y Latinoamérica
    </footer>
  </main>
</BaseLayout>
