---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection, render } from 'astro:content';
import { toTool } from '../../data/tools';

export async function getStaticPaths() {
  const estudios = await getCollection('estudios');
  return estudios.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const site = 'https://agentesva.com';

const allTools = (await getCollection('tools')).map(toTool);
const related = d.herramientas
  .map((slug) => allTools.find((t) => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const fechaFmt = d.fecha.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

const graph: any[] = [
  {
    '@type': 'Article',
    headline: d.titulo,
    description: d.descripcion,
    datePublished: d.fecha.toISOString(),
    dateModified: (d.actualizado ?? d.fecha).toISOString(),
    inLanguage: 'es',
    author: { '@type': 'Organization', name: 'AgentesVA', url: site },
    publisher: { '@type': 'Organization', name: 'AgentesVA', url: site, logo: `${site}/brand/avatar.png` },
    mainEntityOfPage: `${site}/estudios/${entry.id}`,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${site}/` },
      { '@type': 'ListItem', position: 2, name: 'Estudios', item: `${site}/estudios` },
      { '@type': 'ListItem', position: 3, name: d.titulo, item: `${site}/estudios/${entry.id}` },
    ],
  },
];
if (d.faq?.length) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  });
}
const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<BaseLayout title={`${d.titulo} | AgentesVA`} description={d.descripcion}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <SiteHeader />

  <main style="max-width: 760px; margin: 0 auto; padding: 40px 32px 64px;">
    <nav aria-label="Migas" style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-5);">
      <a href="/" class="navlink" style="color: var(--fg-4); text-decoration: none;">Inicio</a> <span aria-hidden="true">/</span>
      <a href="/estudios" class="navlink" style="color: var(--fg-4); text-decoration: none;">Estudios</a> <span aria-hidden="true">/</span> {d.tema}
    </nav>

    <p style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin: 24px 0 0;">{d.tema}</p>
    <h1 style="font-family: var(--serif); font-weight: 400; font-size: clamp(30px, 5.5vw, 46px); line-height: 1.08; letter-spacing: -0.03em; color: #fff; margin: 10px 0 0;">{d.titulo}</h1>
    <p style="font-size: 18px; line-height: 1.55; color: var(--fg-3); margin: 16px 0 0;">{d.descripcion}</p>
    <p style="font-family: var(--mono); font-size: 11px; color: var(--fg-5); margin: 16px 0 0;">AgentesVA · {fechaFmt}</p>

    <article class="prose" style="margin-top: 36px;">
      <Content />
    </article>

    {related.length > 0 && (
      <section style="margin-top: 48px; border-top: 1px solid var(--line); padding-top: 28px;">
        <h2 style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin: 0;">Herramientas mencionadas</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px;">
          {related.map((t) => (
            <a href={`/herramienta/${t.slug}`} class="lift" style="display: inline-flex; align-items: center; gap: 9px; background: var(--panel); border: 1px solid var(--line); border-radius: 30px; padding: 8px 14px 8px 8px; text-decoration: none;">
              <span style={`width: 26px; height: 26px; border-radius: 7px; flex: none; display: flex; align-items: center; justify-content: center; font-family: var(--sans); font-weight: 700; font-size: 13px; color: #fff; background: ${t.color};`}>{t.name.charAt(0)}</span>
              <span style="font-family: var(--sans); font-size: 13.5px; font-weight: 600; color: #fff;">{t.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <a href="/estudios" class="navlink" style="display: inline-flex; align-items: center; gap: 8px; margin-top: 36px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-4); text-decoration: none;">← Todos los estudios</a>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  import { initMotion } from '../../scripts/motion';
  document.addEventListener('astro:page-load', () => initMotion());
</script>
