---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { jsonLdSerialize } from '../../data/schema';

const estudios = (await getCollection('estudios')).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf(),
);
const site = 'https://agentesva.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'CollectionPage', name: 'Estudios de IA', description: 'Comparativas y análisis de herramientas de IA, en español.', url: `${site}/estudios`, inLanguage: 'es' },
    {
      '@type': 'ItemList',
      itemListElement: estudios.map((e, i) => ({ '@type': 'ListItem', position: i + 1, url: `${site}/estudios/${e.id}`, name: e.data.titulo })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${site}/` },
        { '@type': 'ListItem', position: 2, name: 'Estudios', item: `${site}/estudios` },
      ],
    },
  ],
};
---

<BaseLayout
  title="Estudios de IA — Comparativas y guías | AgentesVA"
  description="Comparativas y análisis de herramientas de IA en español: mejores herramientas para X, alternativas a Y, qué elegir para tu negocio."
>
  <script type="application/ld+json" set:html={jsonLdSerialize(jsonLd)} />
  <SiteHeader />

  <main style="max-width: 1200px; margin: 0 auto; padding: 40px 32px 64px;">
    <nav aria-label="Migas" style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-5);">
      <a href="/" class="navlink" style="color: var(--fg-4); text-decoration: none;">Inicio</a> <span aria-hidden="true">/</span> Estudios
    </nav>
    <h1 style="font-family: var(--serif); font-weight: 400; font-size: clamp(30px, 5vw, 44px); letter-spacing: -0.03em; margin: 18px 0 0; color: #fff;">Estudios de IA</h1>
    <p style="font-size: 16px; line-height: 1.6; color: var(--fg-3); margin: 12px 0 0; max-width: 42em;">Comparativas y análisis para decidir qué herramienta de IA usar en tu negocio: "mejores herramientas para X", "alternativas a Y", sin tecnicismos.</p>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 18px; margin-top: 32px;">
      {estudios.map((e) => (
        <ArticleCard href={`/estudios/${e.id}`} titulo={e.data.titulo} descripcion={e.data.descripcion} fecha={e.data.fecha} tema={e.data.tema} tipo="Estudio" />
      ))}
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  import { initMotion } from '../../scripts/motion';
  document.addEventListener('astro:page-load', () => initMotion());
</script>
