---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada — AgentesVA"
  description="La página que buscas no existe o se ha movido."
  noindex={true}
>
  <main
    class="mx-auto flex min-h-screen max-w-2xl flex-col items-start justify-center px-6 py-20"
  >
    <p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-amber-400">
      Error 404
    </p>
    <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
      Página no encontrada
    </h1>
    <p class="mt-6 text-lg text-slate-300">
      La página que buscas no existe o se ha movido.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 font-medium text-slate-950 transition hover:bg-emerald-400"
    >
      ← Volver al inicio
    </a>
  </main>
</BaseLayout>
