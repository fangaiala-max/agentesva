---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getCollection, render } from 'astro:content';
import { toTool } from '../../data/tools';
import { jsonLdSerialize, organization, person, SITE as site } from '../../data/schema';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const allTools = (await getCollection('tools')).map(toTool);
const related = d.herramientas
  .map((slug) => allTools.find((t) => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const fechaFmt = d.fecha.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'NewsArticle',
      headline: d.titulo,
      description: d.descripcion,
      datePublished: d.fecha.toISOString(),
      dateModified: d.fecha.toISOString(),
      inLanguage: 'es',
      author: person,
      publisher: organization,
      mainEntityOfPage: `${site}/noticias/${entry.id}/`,
      url: `${site}/noticias/${entry.id}/`,
      image: `${site}/og.png`,
      isBasedOn: d.fuente.url,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${site}/` },
        { '@type': 'ListItem', position: 2, name: 'Noticias', item: `${site}/noticias/` },
        { '@type': 'ListItem', position: 3, name: d.titulo, item: `${site}/noticias/${entry.id}/` },
      ],
    },
  ],
};
---

<BaseLayout title={`${d.titulo} | AgentesVA`} description={d.descripcion}>
  <script type="application/ld+json" set:html={jsonLdSerialize(jsonLd)} />
  <SiteHeader />

  <main
    data-pagefind-body
    data-pagefind-filter="tipo:Noticia"
    data-pagefind-meta="tipo:Noticia"
    style="max-width: 760px; margin: 0 auto; padding: 40px 32px 64px;"
  >
    <nav aria-label="Migas" data-pagefind-ignore style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-5);">
      <a href="/" class="navlink" style="color: var(--fg-4); text-decoration: none;">Inicio</a> <span aria-hidden="true">/</span>
      <a href="/noticias" class="navlink" style="color: var(--fg-4); text-decoration: none;">Noticias</a> <span aria-hidden="true">/</span> {d.tema}
    </nav>

    <p style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin: 24px 0 0;">{d.tema}</p>
    <h1 style="font-family: var(--serif); font-weight: 400; font-size: clamp(28px, 5vw, 42px); line-height: 1.1; letter-spacing: -0.03em; color: #fff; margin: 10px 0 0;">{d.titulo}</h1>
    <p style="font-size: 18px; line-height: 1.55; color: var(--fg-3); margin: 16px 0 0;">{d.descripcion}</p>
    <p style="font-family: var(--mono); font-size: 11px; color: var(--fg-5); margin: 16px 0 0;">Por Fernando Angulo · AgentesVA · {fechaFmt} · Fuente: <a href={d.fuente.url} target="_blank" rel="nofollow noopener" style="color: var(--accent);">{d.fuente.nombre}</a></p>

    <article class="prose" style="margin-top: 32px;">
      <Content />
    </article>

    {related.length > 0 && (
      <section data-pagefind-ignore style="margin-top: 40px; border-top: 1px solid var(--line); padding-top: 24px;">
        <h2 style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin: 0;">Herramientas relacionadas</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px;">
          {related.map((t) => (
            <a href={`/herramienta/${t.slug}`} class="lift" style="display: inline-flex; align-items: center; gap: 9px; background: var(--panel); border: 1px solid var(--line); border-radius: 30px; padding: 8px 14px 8px 8px; text-decoration: none;">
              <span style={`width: 26px; height: 26px; border-radius: 7px; flex: none; display: flex; align-items: center; justify-content: center; font-family: var(--sans); font-weight: 700; font-size: 13px; color: #fff; background: ${t.color};`}>{t.name.charAt(0)}</span>
              <span style="font-family: var(--sans); font-size: 13.5px; font-weight: 600; color: #fff;">{t.name}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <a href="/noticias" data-pagefind-ignore class="navlink" style="display: inline-flex; align-items: center; gap: 8px; margin-top: 36px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg-4); text-decoration: none;">← Todas las noticias</a>
  </main>

  <SiteFooter />
</BaseLayout>

<script>
  import { initMotion } from '../../scripts/motion';
  document.addEventListener('astro:page-load', () => initMotion());
</script>
