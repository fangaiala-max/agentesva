# AgentesVA — variables de entorno (ejemplo)
# En producción los secretos se cargan desde Doppler, NO desde .env.

# Brevo (email marketing) — usado por api/subscribe.js
BREVO_API_KEY=xkeysib-...
BREVO_LIST_ID=8

# Listas opcionales por origen del alta (si no se definen, cae en BREVO_LIST_ID)
# BREVO_LIST_ID_NEWSLETTER=
# BREVO_LIST_BLOG_NEWSLETTER=
# BREVO_LIST_VOICE_WAITLIST=

# Doble opt-in (DOI) de la newsletter — api/subscribe.js usa DOI solo si
# BREVO_DOI_TEMPLATE_ID está definido (si no, alta directa, como antes).
# El template DOI se crea en el panel de Brevo (Contacts → Forms → Double opt-in).
# BREVO_DOI_TEMPLATE_ID=
# BREVO_DOI_REDIRECT_URL=https://agentesva.com/gracias
