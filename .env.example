# AgentesVA — variables de entorno (ejemplo)
# En producción los secretos se cargan desde Doppler, NO desde .env.

# Brevo (email marketing) — usado por api/subscribe.js
BREVO_API_KEY=xkeysib-...
BREVO_LIST_ID=8

# Listas opcionales por origen del alta (si no se definen, cae en BREVO_LIST_ID)
# BREVO_LIST_ID_NEWSLETTER=
# BREVO_LIST_BLOG_NEWSLETTER=
# BREVO_LIST_VOICE_WAITLIST=

# Doble opt-in (DOI) de la newsletter — api/subscribe.js usa DOI solo si
# BREVO_DOI_TEMPLATE_ID está definido (si no, alta directa, como antes).
# El template DOI se crea en el panel de Brevo (Contacts → Forms → Double opt-in).
# BREVO_DOI_TEMPLATE_ID=
# BREVO_DOI_REDIRECT_URL=https://agentesva.com/gracias

# Anti-bombing: orígenes permitidos para POST /api/subscribe (coma-separados).
# Si no se define, por defecto: https://agentesva.com,https://www.agentesva.com
# Añade el dominio de preview (*.vercel.app) aquí si necesitas probar el form ahí.
# SUBSCRIBE_ALLOWED_ORIGINS=https://agentesva.com,https://www.agentesva.com

# Stripe (entrega de skill packs de pago) — usados por src/pages/descarga.astro
# Clave restringida (Checkout Sessions: lectura). Se lee en RUNTIME (process.env).
STRIPE_SECRET_KEY=rk_...
# Mapa slug→URL de Vercel Blob con los zips de pago, en una sola línea JSON.
DESCARGAS_JSON={"auditor-seguridad-prompts":"https://...","arquitecto-rag":"https://...","pack-dev-ia":"https://..."}

# Google Analytics 4 — Measurement ID (formato G-XXXXXXXXXX). Expuesta al cliente
# (prefijo PUBLIC_). Si está vacía, NO se carga analytics ni se muestra el banner
# de consentimiento (la feature queda desactivada). Usada por ConsentBanner.astro
# y src/scripts/consent.ts.
PUBLIC_GA4_ID=
